ura/5 hover:border-sakura transition-all\"\r\n                  >\r\n                    <div className=\"flex items-center gap-3\">\r\n                      <div className=\"h-10 w-10 rounded-lg bg-sakura/10 flex items-center justify-center\">\r\n                        <FileText className=\"h-5 w-5 text-sakura\" />\r\n                      </div>\r\n                      <div className=\"text-left\">\r\n                        <p className=\"font-bold text-sm\">TГҹв•‘Гӯo TГҹв•‘ВЎp viГҹв•‘в”җt Kanji</p>\r\n                        <p className=\"text-[10px] text-muted-foreground\">XuГҹв•‘Г‘t PDF Worksheet VIP</p>\r\n                      </div>\r\n                    </div>\r\n                    <ChevronRight className=\"h-4 w-4\" />\r\n                  </Button>\r\n                </Link>\r\n              </CardContent>\r\n            </Card>\r\n\r\n            {/* Mini Leaderboard */}\r\n            {leaderboardLoading ? (\r\n              <div className=\"flex justify-center p-4\">\r\n                <Loader2 className=\"h-5 w-5 animate-spin text-muted-foreground\" />\r\n              </div>\r\n            ) : (\r\n              <Leaderboard entries={leaderboard} />\r\n            )}\r\n          </motion.div>\r\n        </div>\r\n\r\n        {/* Achievements Section */}\r\n        <motion.section\r\n          initial={{ opacity: 0, y: 20 }}\r\n          animate={{ opacity: 1, y: 0 }}\r\n          transition={{ delay: 0.4 }}\r\n        >\r\n          <Card className=\"shadow-card\">\r\n            <CardHeader>\r\n              <div className=\"flex items-center justify-between\">\r\n                <CardTitle className=\"flex items-center gap-2\">\r\n                  <Trophy className=\"h-5 w-5 text-gold\" />\r\n                  Thв”ңГЎnh tв”ңВЎch\r\n                </CardTitle>\r\n                <Link to=\"/achievements\">\r\n                  <Button variant=\"ghost\" size=\"sm\">\r\n                    Xem tГҹв•‘Г‘t cГҹв•‘Гә\r\n                    <Chevro