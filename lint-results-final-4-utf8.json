w FileReader();\r\n                          reader.onload = (event) => {\r\n                            const content = event.target?.result as string;\r\n                            setNewVideoSubtitles(content);\r\n                            toast({\r\n                              title: 'File в”ҖГҰв”ңГә tГҹв•‘Гәi',\r\n                              description: `в”ҖГүв”ңГә tГҹв•‘Гәi ${file.name}`,\r\n                            });\r\n                          };\r\n                          reader.readAsText(file);\r\n                        }\r\n                        e.target.value = '';\r\n                      }}\r\n                    />\r\n                    <Button\r\n                      type=\"button\"\r\n                      variant=\"outline\"\r\n                      size=\"sm\"\r\n                      className=\"h-7 text-xs gap-1\"\r\n                      onClick={() => fileInputRef.current?.click()}\r\n                    >\r\n                      <Upload className=\"h-3 w-3\" />\r\n                      TГҹв•‘Гәi file SRT\r\n                    </Button>\r\n                    <span className=\"text-muted-foreground\">hoГҹв•‘в•–c</span>\r\n                    {newVideoUrl && extractYouTubeId(newVideoUrl) && (\r\n                      <a \r\n                        href={`https://downsub.com/?url=https://www.youtube.com/watch?v=${extractYouTubeId(newVideoUrl)}`}\r\n                        target=\"_blank\"\r\n                        rel=\"noopener noreferrer\"\r\n                        className=\"text-sakura hover:underline flex items-center gap-1\"\r\n                      >\r\n                        TГҹв•‘Гәi tГҹв•—ВҪ DownSub <ExternalLink className=\"h-3 w-3\" />\r\n                      </a>\r\n                    )}\r\n                  </div>\r\n                </div>\r\n\r\n                <Button\r\n                  className=\"w-full gap-2\"\r\n                  onClick={handleAddVideo}\r\n                  disabled={processing || !newVideoSubtitles}\r\n                >\r\n                  {processing ? (\r\n                    <>\r\n                      <Loader2 className=\"h-4 w-4 animate-spin\" />\r\n                      в”ҖГүang xГҹв•—ВЎ lв”ңв•ң vГҹв•—Вўi AI...\r\n                    </>\r\n                  ) : (\r\n                    <>\r\n                      <Sparkles className=\"h-4 w-4\" />\r\n                      Thв”ңВ¬m & XГҹв•—ВЎ lв”ңв•ң Video\r\n                    </>\r\n                  )}\r\n                </Button>\r\n              </div>\r\n            </DialogContent>\r\n          </Dialog>\r\n        </div>\r\n\r\n        {/* Favorites Filter */}\r\n        {videos.length > 0 && (\r\n          <div className=\"flex items-center gap-2\">\r\n            <Button\r\n              variant={showFavoritesOnly ? \"default\" : \"outline\"}\r\n              size=\"sm\"\r\n              onClick={() => setShowFavoritesOnly(!showFavoritesOnly)}\r\n              className=\"gap-2\"\r\n            >\r\n              <Heart className={`h-4 w-4 ${showFavoritesOnly ? 'fill-current' : ''}`} />\r\n              Yв”ңВ¬u thв”ңВЎch ({favoriteIds.size})\r\n            </Button>\r\n          </div>\r\n        )}\r\n\r\n        {/* Video List */}\r\n        {filteredVideos.length === 0 ? (\r\n          <Card className=\"shadow-card\">\r\n            <CardContent className=\"py-12 text-center\">\r\n              <BookOpen className=\"h-12 w-12 text-muted-foreground mx-auto mb-4\" />\r\n              <h3 className=\"text-lg font-semibold mb-2\">\r\n                {showFavoritesOnly ? 'Chв•һв–‘a cв”ңв”Ӯ video yв”ңВ¬u thв”ңВЎch' : 'Chв•һв–‘a cв”ңв”Ӯ video nв”ңГЎo'}\r\n              </h3>\r\n              <p className=\"text-muted-foreground mb-4\">\r\n                {showFavoritesOnly \r\n                  ? 'BГҹв•‘Г‘m vв”ңГЎo icon trв”ңГӯi tim в”ҖГҰГҹв•—Гў thв”ңВ¬m video vв”ңГЎo danh sв”ңГӯch yв”ңВ¬u thв”ңВЎch'\r\n                  : 'Thв”ңВ¬m video YouTube в”ҖГҰГҹв•—Гў bГҹв•‘В»t в”