: 'Hв”ңГЎnh trв”ңВјnh bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu tГҹв•—ВҪ nhГҹв•—В»ng в”ҖГҰiГҹв•—Гјu cв•һГӯ bГҹв•‘Гәn nhГҹв•‘Г‘t. Lв”ңГЎm quen vГҹв•—Вўi bГҹв•‘Гәng chГҹв•—В» cв”ңГӯi vв”ңГЎ cв”ңГӯc mГҹв•‘ВҪu cв”ңГіu sв•һГӯ в”ҖГҰГҹв•‘в”Ӯng.',\r\n    color: 'sakura',\r\n    units: [\r\n      {\r\n        id: 1,\r\n        title: 'Unit 1: LГҹв•—ВҘi chв”ңГЎo vв”ңГЎ GiГҹв•—Вўi thiГҹв•—Г§u',\r\n        description: 'HГҹв•—Г¬c cв”ңГӯch chв”ңГЎo hГҹв•—Г…i, giГҹв•—Вўi thiГҹв•—Г§u bГҹв•‘Гәn thв”ңГіn vв”ңГЎ ngв•һв–‘Гҹв•—ВҘi khв”ңГӯc.',\r\n        items: [\r\n          { title: 'TГҹв•—ВҪ vГҹв•—в–’ng & Kanji', type: 'vocabulary', completed: true, link: '/vocabulary' },\r\n          { title: 'NgГҹв•—В» phв”ңГӯp: ~ wa ~ desu', type: 'grammar', completed: true, link: '/grammar' },\r\n          { title: 'LuyГҹв•—Г§n nghe: GiГҹв•—Вўi thiГҹв•—Г§u', type: 'video', completed: false, link: '/video-learning' },\r\n          { title: 'Bв”ңГЎi tГҹв•‘ВЎp Unit 1', type: 'quiz', completed: false, link: '/quiz' },\r\n        ]\r\n      },\r\n      {\r\n        id: 2,\r\n        title: 'Unit 2: в”ҖГүГҹв•—Гҙ vГҹв•‘ВЎt vв”ңГЎ SГҹв•—Ж’ hГҹв•—В»u',\r\n        description: 'HГҹв•—Г¬c cв”ңГӯch hГҹв•—Г…i vв”ңГЎ trГҹв•‘Гә lГҹв•—ВҘi vГҹв•—Гј в”ҖГҰГҹв•—Гҙ vГҹв•‘ВЎt, quyГҹв•—Гјn sГҹв•—Ж’ hГҹв•—В»u (kore, sore, are).',\r\n        items: [\r\n          { title: 'TГҹв•—ВҪ vГҹв•—в–’ng & Kanji', type: 'vocabulary', completed: false, link: '/vocabulary' },\r\n          { title: 'NgГҹв•—В» phв”ңГӯp: kore/sore/are', type: 'grammar', completed: false, link: '/grammar' },\r\n          { title: 'HГҹв•—Г¬c qua video', type: 'video', completed: false, link: '/video-learning' },\r\n          { title: 'KiГҹв•—Гўm tra nhanh', type: 'quiz', completed: false, link: '/quiz' },\r\n        ]\r\n      },\r\n      {\r\n        id: 3,\r\n        title: 'Unit 3: в”ҖГүГҹв•—ГҜa в”ҖГҰiГҹв•—Гўm vв”ңГЎ Phв•һв–‘в•һГӯng hв•һв–‘Гҹв•—Вўng',\r\n        description: 'HГҹв•—Г…i в”ҖГҰв•һв–‘Гҹв•—ВҘng, xв”ңГӯc в”ҖГҰГҹв•—ГҜnh vГҹв•—ГҜ trв”ңВЎ cГҹв•—Вәa в”ҖГҰГҹв•—ГҜa в”ҖГҰiГҹв•—Гўm (koko, soko, asoko).',\r\n        items: [\r\n          { title: 'TГҹв•—ВҪ vГҹв•—в–’ng chuyв”ңВ¬n в”ҖГҰГҹв•—Гј', type: 'vocabulary', completed: false, link: '/vocabulary' },\r\n          { title: 'NgГҹв•—В» phв”ңГӯp: koko/soko/asoko', type: 'grammar', completed: false, link: '/grammar' },\r\n          { title: 'Video thГҹв•—в–’c tГҹв•‘в”җ', type: 'video', completed: false, link: '/video-learning' },\r\n          { title: 'Quiz tГҹв•—ГІng hГҹв•—Гәp', type: 'quiz', completed: false, link: '/quiz' },\r\n        ]\r\n      }\r\n    ]\r\n  },\r\n  n4: {\r\n    title: 'JLPT N4 - Sв•һГӯ cГҹв•‘Г‘p 2',\r\n    description: 'MГҹв•—Ж’ rГҹв•—Г–ng vГҹв•—ГҰn tГҹв•—ВҪ vв”ңГЎ ngГҹв•—В» phв”ңГӯp в”ҖГҰГҹв•—Гў giao tiГҹв•‘в”җp tГҹв•—в–’ nhiв”ңВ¬n hв•һГӯn trong cuГҹв•—Г–c sГҹв•—ГҰng hв”ңГЎng ngв”ңГЎy.',\r\n    color: 'indigo',\r\n    units: [\r\n      {\r\n        id: 1,\r\n        title: 'Unit 1: DГҹв•—в–’ в”ҖГҰГҹв•—ГҜnh vв”ңГЎ KГҹв•‘в”җ hoГҹв•‘Гӯch',\r\n        description: 'Nв”ңв”Ӯi vГҹв•—Гј nhГҹв•—В»ng viГҹв•—Г§c sГҹв•‘В»p lв”ңГЎm trong tв•һв–‘в•һГӯng lai.',\r\n        items: [\r\n          { title: 'TГҹв•—ВҪ vГҹв•—в–’ng trв”ңВјnh в”ҖГҰГҹв•—Г– N4', type: 'vocabulary', completed: false, link: '/vocabulary' },\r\n          { title: 'NgГҹв•—В» phв”ңГӯp: ~ tsumori', type: 'grammar', completed: false, link: '/grammar' },\r\n          { title: 'Video bв”ңГЎi giГҹв•‘Гәng', type: 'video', completed: false, link: '/video-learning' },\r\n        ]\r\n      }\r\n    ]\r\n  }\r\n};\r\n\r\nexport const JLPTLevelDetail = () => {\r\n  const { level } = useParams<{ level: string }>();\r\n  const data = levelData[level?.toLowerCase() || 'n5'];\r\n  \r\n  if (!data) return <div>CГҹв•‘Г‘p в”ҖГҰГҹв•—Г– khв”ңв”Өng tГҹв•—Гҙn tГҹв•‘Гӯi.</div>;\r\n\r\n  const totalItems = data.units.reduce((acc: number, unit: any) => acc + unit.items.length, 0);\r\n  const completedItems = data.units.reduce((acc: number, unit: any) => \r\n    acc + unit.items.filter((item: any) => item.completed).length, 0);\r\n  const overallProgress = (completedItems / totalItems) * 100;\r\n\r\n  const getIcon = (type: string) => {\r\n    switch (type) {\r\n      case 'vocabulary': return <BookOpen className=\"h-4 w-4\" />;\r\n      case 'grammar': return <Book className=\"h-4 w-4\" />;\r\n      case 'video': return <Video className=\"h-4 w-4\" />;\r\n      case 'quiz': return <Zap className=\"h-4 w-4\" />;\r\n      default: return <PlayCircle className=\"h-4 w-4\" />;\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background pb-20\">\r\n      <Navigation />\r\n      \r\n      <main className=\"container py-8 space-y-8\">\r\n        {/* Header & Progress */}\r\n        <div className=\"space-y-4\">\r\n          <Link to=\"/learning-path\">\r\n            <Button variant=\"ghost\" size=\"sm\" className=\"gap-2 mb-2\">\r\n              <ChevronLeft className=\"h-4 w-4\" />\r\n              Quay lГҹв•‘Гӯi lГҹв•—Г– trв”ңВјnh\r\n            </Button>\r\n          </Link>\r\n          \r\n          <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-6\">\r\n            <div className=\"space-y-1\">\r\n              <h1 className=\"text-3xl font-display font-bold flex items-center gap-3\">\r\n                <span className={`px-3 py-1 rounded-lg bg-${data.color}/10 text-${data.color}`}>\r\n                  {level?.toUpperCase()}\r\n                </span>\r\n                {data.title}\r\n              </h1>\r\n              <p className=\"text-muted-foreground max-w-2xl\">\r\n                {data.description}\r\n              </p>\r\n            </div>\r\n            \r\n            <Card className=\"w-full md:w-64 border-primary/10\">\r\n              <CardContent className=\"p-4 space-y-3\">\r\n                <div className=\"flex justify-between text-sm font-medium\">\r\n                  <span>TiГҹв•‘в”җn в”ҖГҰГҹв•—Г– tГҹв•—ГІng thГҹв•—Гў</span>\r\n                  <span>{Math.floor(overallProgress)}%</span>\r\n                </div>\r\n                <Progress value={overallProgress} className={`h-2 bg-${data.color}/20`} />\r\n                <p className=\"text-xs text-muted-foreground text-center\">\r\n                  BГҹв•‘Гӯn в”ҖГҰв”ңГә hoв”ңГЎn thв”ңГЎnh {completedItems}/{totalItems} mГҹв•—Г‘c hГҹв•—Г¬c tГҹв•‘ВЎp\r\n                </p>\r\n              </CardContent>\r\n            </Card>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Units Roadmap */}\r\n        <div className=\"grid lg:grid-cols-3 gap-8\">\r\n          <div className=\"lg:col-span-2 space-y-6\">\r\n            <h2 className=\"text-xl font-bold flex items-center gap-2\">\r\n              <MapIcon className=\"h-5 w-5 text-primary\" />\r\n              Danh sв”ңГӯch bв”ңГЎi hГҹв•—Г¬c\r\n            </h2>\r\n            \r\n            <Accordion type=\"single\" collapsible className=\"space-y-4 w-full\" defaultValue=\"unit-1\">\r\n              {data.units.map((unit: any) => (\r\n                <AccordionItem \r\n                  key={unit.id} \r\n                  value={`unit-${unit.id}`}\r\n                  className=\"border rounded-xl bg-card overflow-hidden shadow-soft px-4 border-primary/5\"\r\n                >\r\n                  <AccordionTrigger className=\"hover:no-underline py-4\">\r\n                    <div className=\"flex items-center gap-4 text-left\">\r\n                      <div className={`w-10 h-10 rounded-full flex items-center justify-center font-bold bg-${data.color}/10 text-${data.color}`}>\r\n                        {unit.id}\r\n                      </div>\r\n                      <div>\r\n                        <h3 className=\"font-bold text-lg\">{unit.title}</h3>\r\n                        <p className=\"text-xs text-muted-foreground line-clamp-1\">{unit.description}</p>\r\n                      </div>\r\n                    </div>\r\n                  </AccordionTrigger>\r\n                  <AccordionContent className=\"pb-4 pt-2\">\r\n                    <div className=\"grid gap-3\">\r\n                      {unit.items.map((item: any, idx: number) => (\r\n                        <Link key={idx} to={`/learning-path/${level}/unit/${unit.id}`}>\r\n                          <div className={`\r\n                            group flex items-center justify-between p-3 rounded-lg border-2 transition-all\r\n                            ${item.completed ? 'border-matcha/20 bg-matcha/5' : 'border-border hover:border-primary/30'}\r\n                          `}>\r\n                            <div className=\"flex items-center gap-3\">\r\n                              <div className={`\r\n                                p-2 rounded-md\r\n                                ${item.completed ? 'bg-matcha text-white' : 'bg-muted text-muted-foreground'}\r\n                              `}>\r\n                                {item.completed ? <CheckCircle2 className=\"h-4 w-4\" /> : getIcon(item.type)}\r\n                              </div>\r\n                              <span className={`font-medium ${item.completed ? 'text-foreground' : 'text-muted-foreground'}`}>\r\n                                {item.title}\r\n                              </span>\r\n                            </div>\r\n                            <ArrowRight className=\"h-4 w-4 text-muted-foreground opacity-0 group-hover:opacity-100 transition-opacity\" />\r\n                          </div>\r\n                        </Link>\r\n                      ))}\r\n                    </div>\r\n                  </AccordionContent>\r\n                </AccordionItem>\r\n              ))}\r\n            </Accordion>\r\n          </div>\r\n\r\n          {/* Sidebar Tools */}\r\n          <div className=\"space-y-6\">\r\n            <Card className=\"shadow-card\">\r\n              <CardHeader>\r\n                <CardTitle className=\"text-lg\">Tв”ңГЎi liГҹв•—Г§u hГҹв•—Г¬c tГҹв•‘ВЎp</CardTitle>\r\n                <CardDescription>Cв”ңГӯc cв”ңв”Өng cГҹв•—Г‘ hГҹв•—Г№ trГҹв•—Гә cho {level?.toUpperCase()}</CardDescription>\r\n              </CardHeader>\r\n              <CardContent className=\"space-y-3\">\r\n                {[\r\n                  { title: 'Tв”ңГЎi liГҹв•—Г§u nghe N5', icon: Video, color: 'text-sky-500', link: '/video-learning' },\r\n                  { title: 'LuyГҹв•—Г§n thi thГҹв•—ВЎ', icon: Trophy, color: 'text-gold', link: '/quiz' },\r\n                  { title: 'Chat vГҹв•—Вўi AI Sensei', icon: Brain, color: 'text-matcha', link: '/ai-tutor' },\r\n                ].map((tool, idx) => (\r\n                  <Link key={idx} to={tool.link}>\r\n                    <Button variant=\"outline\" className=\"w-full justify-start gap-3 h-12 shadow-none\">\r\n                      <tool.icon className={`h-5 w-5 ${tool.color}`} />\r\n                      {tool.title}\r\n                    </Button>\r\n                  </Link>\r\n                ))}\r\n              </CardContent>\r\n            </Card>\r\n\r\n            <Card className=\"bg-gradient-to-br from-sakura to-sakura-dark text-white border-none shadow-elevated\">\r\n              <CardContent className=\"p-6 space-y-4\">\r\n                <div className=\"p-3 bg-white/20 rounded-xl w-fit\">\r\n                  <Star className=\"h-6 w-6 text-yellow-300 fill-yellow-300\" />\r\n                </div>\r\n                <h3 className=\"text-xl font-bold\">MГҹв•‘в•Јo hГҹв•—Г¬c cГҹв•‘Г‘p tГҹв•—ГҰc</h3>\r\n                <p className=\"text-sm text-white/80\">\r\n                  Hв”ңГәy tГҹв•‘ВЎp trung hoв”ңГЎn thв”ңГЎnh 50 Kanji cв•һГӯ bГҹв•‘Гәn trв•һв–‘Гҹв•—Вўc khi chuyГҹв•—Гўn qua Unit 4 в”ҖГҰГҹв•—Гў в”ҖГҰГҹв•‘Гӯt kГҹв•‘в”җt quГҹв•‘Гә tГҹв•—ГҰt nhГҹв•‘Г‘t.\r\n                </p>\r\n                <Button variant=\"secondary\" className=\"w-full text-sakura font-bold\">\r\n                  Xem thв”ңВ¬m\r\n                </Button>\r\n              </CardContent>\r\n            </Card>\r\n          </div>\r\n        </div>\r\n      </main>\r\n    </div>\r\n  );\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\JLPTMockExam.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\JLPTPortal.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\KanjiDetail.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\KanjiWorksheet.tsx","messages":[{"ruleId":"no-empty","severity":2,"message":"Empty block statement.","line":248,"column":201,"nodeType":"BlockStatement","messageId":"unexpected","endLine":248,"endColumn":203,"suggestions":[{"messageId":"suggestComment","data":{"type":"block"},"fix":{"range":[13982,13982],"text":" /* empty */ "},"desc":"Add comment inside empty block statement."}]},{"ruleId":"no-empty","severity":2,"message":"Empty block statement.","line":251,"column":91,"nodeType":"BlockStatement","messageId":"unexpected","endLine":251,"endColumn":93,"suggestions":[{"messageId":"suggestComment","data":{"type":"block"},"fix":{"range":[14108,14108],"text":" /* empty */ "},"desc":"Add comment inside empty block statement."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useRef, useEffect, useCallback } from 'react';\r\nimport { Navigation } from '@/components/Navigation';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Textarea } from '@/components/ui/textarea';\r\nimport { Card, CardContent, CardHeader } from '@/components/ui/card';\r\nimport { Slider } from '@/components/ui/slider';\r\nimport { Label } from '@/components/ui/label';\r\nimport { Switch } from '@/components/ui/switch';\r\nimport {\r\n  Download, Loader2, Sparkles, Settings2, RefreshCw,\r\n  Copy, RotateCcw, Check, BookOpen\r\n} from 'lucide-react';\r\nimport { useToast } from '@/hooks/use-toast';\r\nimport { supabase } from '@/integrations/supabase/client';\r\nimport { cn } from '@/lib/utils';\r\nimport { Badge } from '@/components/ui/badge';\r\nimport jsPDF from 'jspdf';\r\nimport html2canvas from 'html2canvas';\r\nimport { getStrokeOrder } from '@/data/strokeOrder';\r\n\r\n/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Types О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */\r\ntype PaperSize   = 'a4' | 'a5' | 'letter';\r\ntype GhostColor  = 'gray' | 'indigo' | 'sakura' | 'olive';\r\ntype BorderStyle = 'solid' | 'dashed';\r\ntype CellGuide   = 'cross' | 'diagonal' | 'both';\r\ntype SheetTheme  = 'white' | 'cream';\r\ntype LayoutMode  = 'compact' | 'onePerPage';\r\ntype SettingsTab = 'layout' | 'style' | 'display' | 'export';\r\n\r\ninterface KanjiEntry {\r\n  character: string; hanviet: string; meaning: string;\r\n  strokeCount?: number; onReading?: string; kunReading?: string;\r\n}\r\ninterface SheetSettings {\r\n  ghostCells: number; practiceCells: number; cellSize: number;\r\n  paperSize: PaperSize; layoutMode: LayoutMode;\r\n  ghostOpacityMax: number; ghostOpacityMin: number;\r\n  ghostColor: GhostColor; borderWeight: number; borderStyle: BorderStyle;\r\n  sheetTheme: SheetTheme; cellGuide: CellGuide; showCellNumbers: boolean;\r\n  showStrokeOrder: boolean; showHanViet: boolean; showMeaning: boolean;\r\n  showStrokeCount: boolean; showReadings: boolean; showVocabRows: boolean; showPageFooter: boolean;\r\n}\r\n\r\n/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Constants О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */\r\nconst GHOST_COLORS: Record<GhostColor, string> = {\r\n  gray: '#555', indigo: '#4f46e5', sakura: '#e87ca0', olive: '#6b7a3e',\r\n};\r\nconst PAPER_WIDTHS:  Record<PaperSize, number> = { a4: 210, a5: 148, letter: 216 };\r\nconst PAPER_HEIGHTS: Record<PaperSize, number> = { a4: 297, a5: 210, letter: 279 };\r\nconst SHEET_THEMES:  Record<SheetTheme, string> = { white: '#fff', cream: '#fdf8ef' };\r\nconst KANJI_FONT   = '\"Noto Sans JP\",\"Yu Gothic\",\"MS Gothic\",sans-serif';\r\nconst NOTO_URL     = 'https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap';\r\nconst STORAGE_KEY  = 'kanji-worksheet-v3';\r\n\r\nconst DEFAULT: SheetSettings = {\r\n  ghostCells: 9, practiceCells: 3, cellSize: 58, paperSize: 'a4', layoutMode: 'compact',\r\n  ghostOpacityMax: 0.75, ghostOpacityMin: 0.08,\r\n  ghostColor: 'gray', borderWeight: 1.5, borderStyle: 'solid',\r\n  sheetTheme: 'white', cellGuide: 'cross', showCellNumbers: false,\r\n  showStrokeOrder: true, showHanViet: true, showMeaning: true,\r\n  showStrokeCount: true, showReadings: false, showVocabRows: false, showPageFooter: true,\r\n};\r\n\r\nconst PRESETS = [\r\n  { label: 'SГҹв•—ГҰ в”ҖГҰГҹв•‘в”җm N5',   chars: 'ОЈв••ГҮОЈв•‘Г®ОЈв••Г«ПғВўВўОЈв•‘Г¶ПғГ ВЎОЈв••ГўПғГ ВҪОЈв•ЈВҘПғГ¬ГјП„Г–в•ӣПғГ¬ГўОЈв••Г§ПғГҘГҘ' },\r\n  { label: 'Thiв”ңВ¬n nhiв”ңВ¬n', chars: 'Пғв–’в–’Пғв•–ВҘВөВЈВҝВөвӮ§Г№ВөГәВ«ОҰГЁв–’ОҰГ¬Г«П„вҢҗв•‘Вөв•Ўв•–ОҳВўВҝОҳВўВ¬ОҳГіВҝП„ГјВҪВөв–‘в”ӨПғВЈЖ’' },\r\n  { label: 'ThГҹв•—ВҘi gian',   chars: 'ВөГ№Г‘ВөВЈГӘПғв•Јв”ӨВөГ–Г©ПғГӘГҘОЈв•—ГЁПғГ¬ГӘВөВЈВҘПғГұВЈПғГ«Г¬Пғв•ӣГ®ОҳГҮв–’ВөГҝГ‘ПғГұГ…П„ВәГҜПғГҘВј' },\r\n  { label: 'Con ngв•һв–‘Гҹв•—ВҘi',   chars: 'ОЈв•‘в•‘П„Г¶в•–ПғГ‘в”ӮПғВЎГүВөВ»Г¬П„ГӘв•ўПғГ…ГҜПғГ ГӘП„Г¶Ж’ПғВЎВӘПғГ ГӨПғв•қЖ’ПғВәГ«ПғВӘв•Ј' },\r\n  { label: 'в”ҖГүГҹв•—ГҜa в”ҖГҰiГҹв•—Гўm',   chars: 'ПғВ«в•ўПғВўв•ңОЈв•қГңП„Гұв•ӣВөГЎГӯПғв•‘Г№ОҳВәГ ОҳГ»ГҮОҳГјГҙОЈв••ВЎПғГұГ»ОЈв••ГЁОЈв••ГҜПғГ…в”ӮПғв•–ВӘ' },\r\n  { label: 'в”ҖГүГҹв•—Г–ng tГҹв•—ВҪ N4',  chars: 'ПғГҜГІПғГўГ¬ВөГ®ГјОЈв•ңв”җОЈв•ңВЈВөГІГ–П„в”җГҶОҳГҮГјПғГ…Г№ПғГ…Г»ОҰв•Ўв–‘Вөв”Ӯв”ӮП„ВҘГҮОЈв•ңГ…ПғГӘГ§' },\r\n  { label: 'Tв”ңВЎnh tГҹв•—ВҪ N4',  chars: 'ПғВ«Г«ОҳВҪГҝОЈв•ңГ„Пғв•‘ГўОҳГ§Г¬ОҰв•—в•ңОҳГҮЖ’ВөГ№вҢҗОҰГҜГ‘ВөГңГ№Пғв•қв•–Пғв•қв–’ВөВЎГәПғГ‘в•ң' },\r\n  { label: 'Giв”ңГӯo dГҹв•—Г‘c N4', chars: 'ВөГӨГ…ОҰГҜв–’ОҳЖ’в”ӮПғГ®Г»ВөГӨЖ’Вөв•қГіОҰВҝГҝОҰВҝГӘОҰВ¬вӮ§ПғВЎГ№ОҰГҮГ ОҳВўГҘПғГ ВҝОҳГӯГ®ОЈв•—Гә' },\r\n];\r\n\r\n/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Helpers О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */\r\nconst isKanji = (ch: string) => { const c = ch.codePointAt(0) ?? 0; return (c >= 0x4e00 && c <= 0x9fff) || (c >= 0x3400 && c <= 0x4dbf); };\r\nconst parseKanji = (t: string) => { const s = new Set<string>(); const r: string[] = []; for (const ch of t) if (isKanji(ch) && !s.has(ch)) { s.add(ch); r.push(ch); } return r; };\r\nconst ensureFonts = async () => {\r\n  if (!document.querySelector(`link[href=\"${NOTO_URL}\"]`)) { const l = document.createElement('link'); l.rel = 'stylesheet'; l.href = NOTO_URL; document.head.appendChild(l); }\r\n  try { await document.fonts.load('700 48px \"Noto Sans JP\"'); await document.fonts.ready; } catch { await new Promise(r => setTimeout(r, 1500)); }\r\n};\r\n\r\n/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Cell guide SVG О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */\r\nconst Guide: React.FC<{ guide: CellGuide; size: number }> = ({ guide, size }) => (\r\n  <svg style={{ position:'absolute',top:0,left:0,width:'100%',height:'100%',pointerEvents:'none' }} viewBox={`0 0 ${size} ${size}`} preserveAspectRatio=\"none\">\r\n    {(guide==='cross'||guide==='both')&&<><line x1=\"0\" y1={size/2} x2={size} y2={size/2} stroke=\"#e0e0e0\" strokeWidth=\"0.6\"/><line x1={size/2} y1=\"0\" x2={size/2} y2={size} stroke=\"#e0e0e0\" strokeWidth=\"0.6\"/></>}\r\n    {(guide==='diagonal'||guide==='both')&&<><line x1=\"0\" y1=\"0\" x2={size} y2={size} stroke=\"#e8e8e8\" strokeWidth=\"0.6\"/><line x1={size} y1=\"0\" x2=\"0\" y2={size} stroke=\"#e8e8e8\" strokeWidth=\"0.6\"/></>}\r\n  </svg>\r\n);\r\n\r\n/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ WorksheetRow О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */\r\nconst WorksheetRow: React.FC<{ entry: KanjiEntry; s: SheetSettings }> = ({ entry, s }) => {\r\n  const steps = getStrokeOrder(entry.character);\r\n  const total = 1 + s.ghostCells + s.practiceCells;\r\n  const gc = GHOST_COLORS[s.ghostColor];\r\n  const bg = SHEET_THEMES[s.sheetTheme];\r\n  const ob = `${s.borderWeight}px solid #222`;\r\n  const ib = s.borderStyle==='dashed'?'1px dashed #ccc':'1px solid #d4d4d4';\r\n  const cell: React.CSSProperties = { position:'relative',display:'inline-flex',alignItems:'center',justifyContent:'center',width:`${s.cellSize}px`,height:`${s.cellSize}px`,flexShrink:0,overflow:'hidden',boxSizing:'border-box' };\r\n  return (\r\n    <div style={{ marginBottom:20, pageBreakAfter:s.layoutMode==='onePerPage'?'always':'auto', breakInside:'avoid' }}>\r\n      {(s.showHanViet||s.showMeaning||s.showStrokeCount)&&(\r\n        <div style={{ display:'flex',gap:6,alignItems:'baseline',fontFamily:'Arial,sans-serif',marginBottom:1 }}>\r\n          {s.showHanViet&&<span style={{ fontWeight:900,fontSize:12,letterSpacing:'0.1em',textTransform:'uppercase' }}>{entry.hanviet||entry.character}</span>}\r\n          {s.showMeaning&&entry.meaning&&<span style={{ fontSize:10,color:'#666' }}>({entry.meaning})</span>}\r\n          {s.showStrokeCount&&!steps&&entry.strokeCount&&<span style={{ fontSize:9,color:'#aaa' }}>{entry.strokeCount} nв”ңвҢҗt</span>}\r\n        </div>\r\n      )}\r\n      {s.showReadings&&(entry.onReading||entry.kunReading)&&(\r\n        <div style={{ fontSize:10,color:'#888',fontFamily:KANJI_FONT,marginBottom:1,display:'flex',gap:6 }}>\r\n          {entry.onReading&&<span>ОҳЖ’в”Ӯ: <b>{entry.onReading}</b></span>}\r\n          {entry.kunReading&&<span>ОҰВҝГҙ: <b>{entry.kunReading}</b></span>}\r\n        </div>\r\n      )}\r\n      {s.showStrokeOrder&&steps&&(\r\n        <div style={{ display:'flex',alignItems:'center',gap:4,marginBottom:3,fontFamily:KANJI_FONT,fontSize:13,color:'#444',lineHeight:1 }}>\r\n          {steps.map((x,i)=><span key={i}>{x}</span>)}\r\n          {s.showStrokeCount&&entry.strokeCount&&<span style={{ fontSize:8,color:'#bbb',marginLeft:2,fontFamily:'Arial' }}>{entry.strokeCount} nв”ңвҢҗt</span>}\r\n        </div>\r\n      )}\r\n      <div style={{ display:'flex',border:ob,width:`${s.cellSize*total}px`,boxSizing:'border-box',backgroundColor:bg }}>\r\n        <div style={{ ...cell,borderRight:ob,backgroundColor:bg }}>\r\n          <Guide guide={s.cellGuide} size={s.cellSize}/>\r\n          <span style={{ fontFamily:KANJI_FONT,fontSize:`${s.cellSize*.44}px`,fontWeight:900,color:'#111',lineHeight:1,position:'relative' }}>{entry.character}</span>\r\n        </div>\r\n        {Array.from({length:s.ghostCells}).map((_,i)=>{\r\n          const t=s.ghostCells===1?1:i/(s.ghostCells-1);\r\n          const op=s.ghostOpacityMax-t*(s.ghostOpacityMax-s.ghostOpacityMin);\r\n          return(\r\n            <div key={`g${i}`} style={{ ...cell,borderRight:i===s.ghostCells-1?ob:ib,backgroundColor:bg }}>\r\n              <Guide guide={s.cellGuide} size={s.cellSize}/>\r\n              {s.showCellNumbers&&<span style={{ position:'absolute',top:2,left:3,fontSize:8,color:'#bbb',fontFamily:'Arial',lineHeight:1 }}>{i+1}</span>}\r\n              <span style={{ fontFamily:KANJI_FONT,fontSize:`${s.cellSize*.37}px`,fontWeight:400,color:gc,opacity:op,lineHeight:1,position:'relative' }}>{entry.character}</span>\r\n            </div>\r\n          );\r\n        })}\r\n        {Array.from({length:s.practiceCells}).map((_,i)=>(\r\n          <div key={`e${i}`} style={{ ...cell,borderLeft:i>0?ib:undefined,backgroundColor:bg }}><Guide guide={s.cellGuide} size={s.cellSize}/></div>\r\n        ))}\r\n      </div>\r\n      {s.showVocabRows&&(\r\n        <div style={{ width:`${s.cellSize*total}px`,marginTop:3 }}>\r\n          <div style={{ fontSize:8,color:'#ccc',fontFamily:'Arial',marginBottom:2 }}>TГҹв•—В¬ VГҹв•—в–‘NG</div>\r\n          {[0,1].map(i=><div key={i} style={{ height:`${s.cellSize*.44}px`,borderBottom:'1px solid #ddd',marginBottom:4 }}/>)}\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n};\r\n\r\n/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ PrintSheet О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */\r\nconst PrintSheet = React.forwardRef<HTMLDivElement,{entries:KanjiEntry[];s:SheetSettings;title?:string}>(({entries,s,title},ref)=>{\r\n  const w=s.cellSize*(1+s.ghostCells+s.practiceCells)+100;\r\n  return(\r\n    <div ref={ref} style={{ width:`${w}px`,backgroundColor:SHEET_THEMES[s.sheetTheme],padding:'36px 50px',fontFamily:'Arial,sans-serif',boxSizing:'border-box' }}>\r\n      <div style={{ display:'flex',justifyContent:'space-between',alignItems:'flex-end',marginBottom:22,borderBottom:'2px solid #111',paddingBottom:8 }}>\r\n        <div>\r\n          <div style={{ fontSize: 16, fontWeight: 900, letterSpacing: '0.15em' }}>{title || 'LUYГҹв•—ГҘN VIГҹв•‘в•ӣT KANJI'}</div>\r\n          <div style={{ fontSize:9,color:'#aaa',marginTop:2 }}>TГҹв•‘ВЎp viГҹв•‘в”җt Kanji в”¬в•– LexLoveLoom</div>\r\n        </div>\r\n        <div style={{ fontSize:10,color:'#999',textAlign:'right',lineHeight:1.8 }}>\r\n          <div>HГҹв•—Г¬ tв”ңВ¬n: ______________________</div>\r\n          <div>Ngв”ңГЎy: {new Date().toLocaleDateString('vi-VN')}</div>\r\n        </div>\r\n      </div>\r\n      {entries.map(e=><WorksheetRow key={e.character} entry={e} s={s}/>)}\r\n      {s.showPageFooter&&<div style={{ marginTop:10,paddingTop:8,borderTop:'1px solid #eee',fontSize:9,color:'#ccc',textAlign:'center' }}>Kaizen Kanji Coach в”¬в•– LexLoveLoom в”¬в•– {new Date().getFullYear()}</div>}\r\n    </div>\r\n  );\r\n});\r\nPrintSheet.displayName='PrintSheet';\r\n\r\n/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Setting atoms О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */\r\nconst SRow: React.FC<{label:string;val:string;note?:string;children:React.ReactNode}>=({label,val,note,children})=>(\r\n  <div className=\"space-y-1.5\">\r\n    <div className=\"flex justify-between items-center\">\r\n      <span className=\"text-[11px] font-semibold text-muted-foreground uppercase tracking-wide\">{label}</span>\r\n      <span className=\"text-[11px] font-bold text-sakura bg-sakura/10 px-2 py-0.5 rounded\">{val}</span>\r\n    </div>\r\n    {children}\r\n    {note&&<p className=\"text-[10px] text-muted-foreground\">{note}</p>}\r\n  </div>\r\n);\r\n\r\nconst SToggle: React.FC<{label:string;desc?:string;checked:boolean;on:(v:boolean)=>void}>=({label,desc,checked,on})=>(\r\n  <div className=\"flex items-center justify-between py-3 border-b border-sakura-light/30 last:border-0 hover:bg-sakura-light/20 px-2 rounded-lg transition-colors\">\r\n    <div className=\"pr-4\">\r\n      <p className=\"text-[12px] font-bold text-slate-700\">{label}</p>\r\n      {desc&&<p className=\"text-[10px] text-slate-400 font-medium leading-tight mt-0.5\">{desc}</p>}\r\n    </div>\r\n    <Switch checked={checked} onCheckedChange={on}/>\r\n  </div>\r\n);\r\n\r\nconst SChips: React.FC<{opts:{v:string;l:string}[];val:string;on:(v:string)=>void}>=({opts,val,on})=>(\r\n  <div className=\"flex flex-wrap gap-1.5 p-1 bg-sakura-light/30 rounded-xl border border-sakura-light/50\">\r\n    {opts.map(o=>(\r\n      <button \r\n        key={o.v} \r\n        onClick={()=>on(o.v)}\r\n        className={cn(\r\n          \"px-4 py-1.5 rounded-lg text-[11px] font-bold transition-all\",\r\n          val === o.v \r\n            ? \"bg-white text-sakura shadow-sm ring-1 ring-sakura/20\" \r\n            : \"text-slate-400 hover:text-sakura\"\r\n        )}\r\n      >{o.l}</button>\r\n    ))}\r\n  </div>\r\n);\r\n\r\n/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Main Page О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */\r\nexport const KanjiWorksheet = () => {\r\n  const [input,     setInput]     = useState('ОЈв•—ГЁП„Г„Г«ОЈв•‘ГұПғГүГӘВөВЎвҢҗОҰГ®в•ўПғв•қГҙОҳВўв–“П„В«Г№Пғв–‘Г…');\r\n  const [list,      setList]      = useState<KanjiEntry[]>([]);\r\n  const [loading,   setLoading]   = useState(false);\r\n  const [exporting, setExporting] = useState(false);\r\n  const [showAdv,   setShowAdv]   = useState(false);\r\n  const [tab,       setTab]       = useState<SettingsTab>('layout');\r\n  const [s,         setS]         = useState<SheetSettings>(DEFAULT);\r\n  const [title,     setTitle]     = useState('');\r\n  const [copied,    setCopied]    = useState(false);\r\n  const [previewScale, setPreviewScale] = useState(0.72);\r\n  const previewContainerRef = useRef<HTMLDivElement>(null);\r\n  const ref = useRef<HTMLDivElement>(null);\r\n  const { toast } = useToast();\r\n  const set = useCallback(<K extends keyof SheetSettings>(k:K,v:SheetSettings[K])=>setS(p=>({...p,[k]:v})),[]);\r\n\r\n  const TABS: {id:SettingsTab;label:string}[] = [\r\n    {id:'layout',label:'BГҹв•—ГҰ cГҹв•—Г‘c'},{id:'style',label:'KiГҹв•—Гўu dв”ңГӯng'},{id:'display',label:'HiГҹв•—Гўn thГҹв•—ГҜ'},{id:'export',label:'XuГҹв•‘Г‘t PDF'},\r\n  ];\r\n\r\n  /* Responsive preview scale */\r\n  useEffect(() => {\r\n    const update = () => {\r\n      if (!previewContainerRef.current) return;\r\n      const cw = previewContainerRef.current.clientWidth - 32;\r\n      const contentW = s.cellSize * (1 + s.ghostCells + s.practiceCells) + 100;\r\n      setPreviewScale(Math.min(0.82, Math.max(0.3, cw / contentW)));\r\n    };\r\n    update();\r\n    window.addEventListener('resize', update);\r\n    return () => window.removeEventListener('resize', update);\r\n  }, [s.cellSize, s.ghostCells, s.practiceCells, list.length]);\r\n\r\n  /* localStorage */\r\n  useEffect(() => {\r\n    try { const d=JSON.parse(localStorage.getItem(STORAGE_KEY)||'{}'); if(d.s)setS({...DEFAULT,...d.s}); if(d.input)setInput(d.input); if(d.list)setList(d.list); if(d.title)setTitle(d.title); } catch {}\r\n  }, []);\r\n  useEffect(() => {\r\n    try { localStorage.setItem(STORAGE_KEY,JSON.stringify({s,input,list,title})); } catch {}\r\n  }, [s,input,list,title]);\r\n\r\n  const generate = async () => {\r\n    const chars=parseKanji(input);\r\n    if(!chars.length){toast({title:'Vui lв”ңв–“ng nhГҹв•‘ВЎp Kanji',variant:'destructive'});return;}\r\n    setLoading(true); setList([]);\r\n    try {\r\n      const r=await Promise.all(chars.map(async(ch):Promise<KanjiEntry>=>{\r\n        try{const{data}=await supabase.functions.invoke('kanji-details',{body:{character:ch}});const k=data?.kanji;\r\n          return{character:ch,hanviet:k?.hanviet||ch,meaning:k?.meaning_vi||k?.meaning||'',strokeCount:k?.stroke_count,onReading:k?.on_reading,kunReading:k?.kun_reading};\r\n        }catch{return{character:ch,hanviet:ch,meaning:''};}\r\n      }));\r\n      setList(r);\r\n    } finally { setLoading(false); }\r\n  };\r\n\r\n  const copy = async () => {\r\n    await navigator.clipboard.writeText(list.map(k=>k.character).join(''));\r\n    setCopied(true); setTimeout(()=>setCopied(false),2000);\r\n    toast({title:'в”ҖГүв”ңГә copy!'});\r\n  };\r\n\r\n  const exportPDF = async () => {\r\n    if(!ref.current||!list.length)return;\r\n    setExporting(true);\r\n    try{\r\n      toast({title:'О“Г…в”Ӯ в”ҖГүang tГҹв•‘Гәi font...'});\r\n      await ensureFonts();\r\n      const el=ref.current;\r\n      el.style.cssText='position:fixed;top:-99999px;left:0;z-index:-1;display:block;';\r\n      await new Promise(r=>setTimeout(r,400));\r\n      const cv=await html2canvas(el,{useCORS:true,allowTaint:false,backgroundColor:SHEET_THEMES[s.sheetTheme],logging:false,\r\n        onclone:(doc)=>{const l=doc.createElement('link');l.rel='stylesheet';l.href=NOTO_URL;doc.head.appendChild(l);}\r\n      } as Parameters<typeof html2canvas>[1]);\r\n      el.style.cssText='';\r\n      const pw=PAPER_WIDTHS[s.paperSize],ph=PAPER_HEIGHTS[s.paperSize];\r\n      const pdf=new jsPDF({orientation:'portrait',unit:'mm',format:[pw,ph]});\r\n      const iw=pw,ih=(cv.height*pw)/cv.width;\r\n      let oy=0,pg=0;\r\n      while(oy<ih){if(pg>0)pdf.addPage([pw,ph]);pdf.addImage(cv.toDataURL('image/png'),'PNG',0,-oy,iw,ih);oy+=ph;pg++;}\r\n      pdf.save(`kanji-ws-${Date.now()}.pdf`);\r\n      toast({title:'О“ВЈГ  в”ҖГүв”ңГә tГҹв•‘Гәi PDF!',description:`${list.length} Kanji в”¬в•– ${s.paperSize.toUpperCase()}`});\r\n    }catch(e){console.error(e);toast({title:'LГҹв•—Г№i xuГҹв•‘Г‘t PDF',variant:'destructive'});}\r\n    finally{setExporting(false);}\r\n  };\r\n\r\n  const total=1+s.ghostCells+s.practiceCells;\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background\">\r\n      <Navigation />\r\n      \r\n      <main className=\"max-w-5xl mx-auto px-4 py-8 sm:py-12 space-y-8\">\r\n        \r\n        {/* --- Hero Section --- */}\r\n        <div className=\"text-center space-y-2 relative\">\r\n          <div className=\"absolute -top-10 left-1/2 -translate-x-1/2 w-48 h-48 bg-sakura/5 rounded-full blur-3xl -z-10\" />\r\n          <h1 className=\"text-3xl sm:text-5xl font-black text-sakura-dark tracking-tight\">\r\n            Kanji Worksheet\r\n          </h1>\r\n          <p className=\"text-muted-foreground text-lg max-w-lg mx-auto\">\r\n            TГҹв•‘Гӯo trang luyГҹв•—Г§n viГҹв•‘в”җt Kanji cв”ңГӯ nhв”ңГіn hв”ңв”Ӯa chГҹв•—Г« trong giв”ңГіy lв”ңГӯt.\r\n          </p>\r\n        </div>\r\n\r\n        {/* --- Presets Bar --- */}\r\n        <div className=\"flex gap-2 overflow-x-auto pb-2 no-scrollbar px-1\">\r\n          {PRESETS.map((p) => (\r\n            <button \r\n              key={p.label} \r\n              onClick={() => setInput(p.chars)}\r\n              className=\"flex-shrink-0 px-4 py-2 rounded-xl text-xs font-bold bg-white border border-sakura-light/50 text-sakura-dark hover:bg-sakura-light/30 transition-all active:scale-95 shadow-sm\"\r\n            >\r\n              {p.label}\r\n            </button>\r\n          ))}\r\n        </div>\r\n\r\n        {/* --- Main Workspace --- */}\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\r\n          \r\n          {/* Left Column: Input & Settings */}\r\n          <div className=\"lg:col-span-5 space-y-6\">\r\n            <Card className=\"border border-slate-200 shadow-sm rounded-xl bg-white overflow-hidden\">\r\n              <CardContent className=\"p-6 space-y-6\">\r\n                \r\n                <div className=\"space-y-3\">\r\n                  <div className=\"flex justify-between items-end\">\r\n                    <Label className=\"text-sm font-bold text-slate-700 ml-1\">NhГҹв•‘ВЎp Kanji cГҹв•—Вәa bГҹв•‘Гӯn</Label>\r\n                    <Badge variant=\"outline\" className=\"bg-sakura-light/20 text-sakura border-sakura-light/50 text-[10px]\">\r\n                      {parseKanji(input).length} kв”ңв•ң tГҹв•—в–’\r\n                    </Badge>\r\n                  </div>\r\n                  <div className=\"relative group\">\r\n                    <Textarea \r\n                      value={input} \r\n                      onChange={e => setInput(e.target.value)}\r\n                      placeholder=\"NhГҹв•‘ВЎp Kanji tГҹв•‘Гӯi в”ҖГҰв”ңГіy ( vв”ңВЎ dГҹв•—Г‘: ОЈв•—ГЁП„Г„Г«ОЈв•‘ГұПғГүГӘ...) \"\r\n                      className=\"text-2xl sm:text-3xl tracking-[0.3em] h-32 resize-none rounded-2xl border-2 border-slate-100 focus:border-slate-300 font-jp bg-slate-50/50 p-6 transition-all\"\r\n                    />\r\n                  </div>\r\n                </div>\r\n\r\n                <div className=\"flex items-center gap-3\">\r\n                  <Button \r\n                    onClick={generate} \r\n                    disabled={loading || !input.trim()}\r\n                    className=\"flex-1 bg-sakura hover:bg-sakura-dark text-white font-bold rounded-xl h-12 transition-all active:scale-95 shadow-md shadow-sakura/10\"\r\n                  >\r\n                    {loading ? (\r\n                      <><Loader2 className=\"h-5 w-5 animate-spin mr-2\" /> в”ҖГүang tГҹв•‘Гӯo...</>\r\n                    ) : (\r\n                      <><Sparkles className=\"h-5 w-5 mr-2\" /> TГҹв•‘Гӯo Worksheet</>\r\n                    )}\r\n                  </Button>\r\n                  \r\n                  <Button \r\n                    variant=\"outline\"\r\n                    onClick={() => setShowAdv(!showAdv)}\r\n                    className={cn(\r\n                      \"w-12 h-12 rounded-xl border-2 transition-all p-0\",\r\n                      showAdv ? \"bg-sakura-light border-sakura-light text-sakura-dark font-bold\" : \"bg-white border-sakura-light/50 text-sakura/60 hover:text-sakura hover:border-sakura\"\r\n                    )}\r\n                  >\r\n                    <Settings2 className=\"h-5 w-5\" />\r\n                  </Button>\r\n                </div>\r\n\r\n                {list.length > 0 && (\r\n                  <div className=\"flex items-center justify-between pt-4 border-t border-sakura-light/30\">\r\n                    <div className=\"flex gap-2\">\r\n                      <Button onClick={copy} variant=\"ghost\" size=\"sm\" className=\"h-8 px-3 rounded-lg text-sakura/70 hover:text-sakura hover:bg-sakura-light/20 gap-1.5\">\r\n                        {copied ? (\r\n                          <><Check className=\"h-3.5 w-3.5 text-green-500\" /> <span className=\"text-xs font-bold text-green-600\">в”ҖГүв”ңГә lв•һв–‘u</span></>\r\n                        ) : (\r\n                          <><Copy className=\"h-3.5 w-3.5\" /> <span className=\"text-xs font-bold\">Copy Kanji</span></>\r\n                        )}\r\n                      </Button>\r\n                      <Button onClick={() => { setList([]); setInput(''); }} variant=\"ghost\" size=\"sm\" className=\"h-8 px-3 rounded-lg text-slate-400 hover:text-sakura hover:bg-sakura-light/20 gap-1.5\">\r\n                        <RefreshCw className=\"h-3.5 w-3.5\" />\r\n                        <span className=\"text-xs font-bold\">Lв”ңГЎm lГҹв•‘Гӯi</span>\r\n                      </Button>\r\n                    </div>\r\n                  </div>\r\n                )}\r\n              </CardContent>\r\n            </Card>\r\n\r\n            {/* Settings Panel */}\r\n            {showAdv && (\r\n              <Card className=\"border border-slate-200 shadow-sm rounded-xl bg-white overflow-hidden\">\r\n                <CardContent className=\"p-6 space-y-6\">\r\n                  <div className=\"flex items-center justify-between pb-4 border-b border-slate-50\">\r\n                    <div className=\"flex gap-1 p-1 bg-slate-50 rounded-xl overflow-x-auto no-scrollbar border border-slate-100\">\r\n                      {TABS.map(t => (\r\n                        <button \r\n                          key={t.id} \r\n                          onClick={() => setTab(t.id)}\r\n                          className={cn(\r\n                            \"px-4 py-1.5 rounded-lg text-[11px] font-bold transition-all whitespace-nowrap\",\r\n                            tab === t.id ? \"bg-white text-slate-900 shadow-sm\" : \"text-slate-400 hover:text-slate-600\"\r\n                          )}\r\n                        >\r\n                          {t.label}\r\n                        </button>\r\n                      ))}\r\n                    </div>\r\n                  </div>\r\n\r\n                      <div className=\"min-h-[200px]\">\r\n                        {/* Tab Content Mapping */}\r\n                        {tab === 'layout' && (\r\n                          <div className=\"grid grid-cols-1 gap-6\">\r\n                            <div className=\"grid grid-cols-2 gap-4\">\r\n                              <SRow label=\"в”ңГ¶ ghost\" val={`${s.ghostCells}`}>\r\n                                <Slider min={3} max={14} step={1} value={[s.ghostCells]} onValueChange={([v]) => set('ghostCells', v)} />\r\n                              </SRow>\r\n                              <SRow label=\"в”ңГ¶ trГҹв•—ГҰng\" val={`${s.practiceCells}`}>\r\n                                <Slider min={1} max={8} step={1} value={[s.practiceCells]} onValueChange={([v]) => set('practiceCells', v)} />\r\n                              </SRow>\r\n                            </div>\r\n                            <SRow label=\"Kв”ңВЎch thв•һв–‘Гҹв•—Вўc в”ңв”Ө\" val={`${s.cellSize}px`} note={`MГҹв•—Г–t hв”ңГЎng cв”ңв”Ӯ tГҹв•—ГІng cГҹв•—Г–ng ${total} в”ңв”Ө`}>\r\n                              <Slider min={44} max={80} step={2} value={[s.cellSize]} onValueChange={([v]) => set('cellSize', v)} />\r\n                            </SRow>\r\n                            <div className=\"grid grid-cols-2 gap-4\">\r\n                              <div className=\"space-y-2\">\r\n                                <Label className=\"text-[10px] font-black uppercase text-slate-400 ml-1\">KhГҹв•—ГІ giГҹв•‘Г‘y</Label>\r\n                                <SChips val={s.paperSize} on={v => set('paperSize', v as PaperSize)} opts={[{ v: 'a4', l: 'A4' }, { v: 'a5', l: 'A5' }, { v: 'letter', l: 'Letter' }]} />\r\n                              </div>\r\n                              <div className=\"space-y-2\">\r\n                                <Label className=\"text-[10px] font-black uppercase text-slate-400 ml-1\">BГҹв•—ГҰ cГҹв•—Г‘c PDF</Label>\r\n                                <SChips val={s.layoutMode} on={v => set('layoutMode', v as LayoutMode)} opts={[{ v: 'compact', l: 'GГҹв•—Г–p chung' }, { v: 'onePerPage', l: '1 Kanji/trang' }]} />\r\n                              </div>\r\n                            </div>\r\n                            <div className=\"space-y-2\">\r\n                              <Label className=\"text-[10px] font-black uppercase text-slate-400 ml-1\">Tiв”ңВ¬u в”ҖГҰГҹв•—Гј trang</Label>\r\n                              <input \r\n                                value={title} \r\n                                onChange={e => setTitle(e.target.value)} \r\n                                placeholder=\"LuyГҹв•—Г§n viГҹв•‘в”җt Kanji\"\r\n                                className=\"w-full text-sm font-bold border border-sakura-light/50 rounded-xl px-4 py-2.5 bg-white focus:outline-none focus:border-sakura transition-all\"\r\n                              />\r\n                            </div>\r\n                          </div>\r\n                        )}\r\n\r\n                        {tab === 'style' && (\r\n                          <div className=\"grid grid-cols-1 gap-6\">\r\n                            <div className=\"grid grid-cols-2 gap-4\">\r\n                              <SRow label=\"MГҹв•—ВҘ nhГҹв•‘Г‘t\" val={`${Math.round(s.ghostOpacityMin * 100)}%`}>\r\n                                <Slider min={2} max={30} step={1} value={[Math.round(s.ghostOpacityMin * 100)]} onValueChange={([v]) => set('ghostOpacityMin', v / 100)} />\r\n                              </SRow>\r\n                              <SRow label=\"Rв”ңв•Ў nhГҹв•‘Г‘t\" val={`${Math.round(s.ghostOpacityMax * 100)}%`}>\r\n                                <Slider min={30} max={100} step={5} value={[Math.round(s.ghostOpacityMax * 100)]} onValueChange={([v]) => set('ghostOpacityMax', v / 100)} />\r\n                              </SRow>\r\n                            </div>\r\n                            <div className=\"grid grid-cols-2 gap-4\">\r\n                              <SRow label=\"в”ҖГүГҹв•—Г– dв”ңГЎy viГҹв•—Гјn\" val={`${s.borderWeight}px`}>\r\n                                <Slider min={1} max={3} step={0.5} value={[s.borderWeight]} onValueChange={([v]) => set('borderWeight', v)} />\r\n                              </SRow>\r\n                              <div className=\"space-y-2\">\r\n                                <Label className=\"text-[10px] font-black uppercase text-slate-400 ml-1\">KiГҹв•—Гўu viГҹв•—Гјn</Label>\r\n                                <SChips val={s.borderStyle} on={v => set('borderStyle', v as BorderStyle)} opts={[{ v: 'solid', l: 'LiГҹв•—Гјn' }, { v: 'dashed', l: 'в”ҖГүГҹв•—вҢҗt' }]} />\r\n                  