ols-2 gap-4\">\r\n                                {[\r\n                                  { l: 'KhГҹв•—ГІ giГҹв•‘Г‘y', v: s.paperSize.toUpperCase() },\r\n                                  { l: 'Kanji', v: `${list.length} tГҹв•—ВҪ` },\r\n                                  { l: 'CГҹв•—Гӯ в”ңв”Ө', v: `${s.cellSize}px` },\r\n                                  { l: 'BГҹв•—ГҰ cГҹв•—Г‘c', v: s.layoutMode === 'compact' ? 'GГҹв•—Г–p' : 'RГҹв•—ВҘi' }\r\n                                ].map(item => (\r\n                                  <div key={item.l} className=\"space-y-1\">\r\n                                    <p className=\"text-[10px] text-slate-400\">{item.l}</p>\r\n                                    <p className=\"text-sm font-bold text-slate-700\">{item.v}</p>\r\n                                  </div>\r\n                                ))}\r\n                              </div>\r\n                            </div>\r\n                            <Button \r\n                              onClick={exportPDF} \r\n                              disabled={exporting || !list.length}\r\n                              className=\"w-full bg-slate-900 hover:bg-black text-white font-bold rounded-xl h-12 transition-all\"\r\n                            >\r\n                              {exporting ? (\r\n                                <><Loader2 className=\"h-5 w-5 animate-spin mr-2\" /> в”ҖГүang chuГҹв•‘вҢҗn bГҹв•—ГҜ...</>\r\n                              ) : (\r\n                                <><Download className=\"h-5 w-5 mr-2\" /> TГҹв•‘Гәi vГҹв•—Гј PDF ngay</>\r\n                              )}\r\n                            </Button>\r\n                          </div>\r\n                        )}\r\n                      </div>\r\n                    </CardContent>\r\n                  </Card>\r\n                )}\r\n              </div>\r\n\r\n          {/* Right Column: Live Preview */}\r\n          <div className=\"lg:col-span-7\">\r\n            {list.length > 0 ? (\r\n              <div className=\"space-y-4\">\r\n                <div className=\"flex items-center justify-between px-4\">\r\n                  <h3 className=\"text-sm font-bold text-slate-500 uppercase tracking-widest\">\r\n                     BГҹв•‘Гәn xem trв•һв–‘Гҹв•—Вўc trГҹв•—в–’c tiГҹв•‘в”җp\r\n                  </h3>\r\n                </div>\r\n\r\n                <Card className=\"border border-slate-200 shadow-sm rounded-xl bg-white overflow-hidden\">\r\n                  <CardHeader className=\"p-4 bg-slate-50 flex flex-row items-center justify-between border-b border-slate-100\">\r\n                    <div className=\"flex items-center gap-3\">\r\n                      <div className=\"leading-tight\">\r\n                        <p className=\"text-sm font-bold text-slate-800\">{title || 'LuyГҹв•—Г§n viГҹв•‘в”җt Kanji'}</p>\r\n                        <p className=\"text-[10px] text-slate-400 font-medium uppercase\">{s.paperSize} Worksheet</p>\r\n                      </div>\r\n                    </div>\r\n                    <Button \r\n                      onClick={exportPDF} \r\n                      disabled={exporting} \r\n                      size=\"sm\"\r\n                      className=\"bg-sakura hover:bg-sakura-dark text-white rounded-lg gap-2 h-9 px-4 font-bold transition-all shadow-sm\"\r\n                    >\r\n                      {exporting ? <Loader2 className=\"h-4 w-4 animate-spin\" /> : <><Download className=\"h-4 w-4\" /> TГҹв•‘Гәi PDF</>}\r\n                    </Button>\r\n                  </CardHeader>\r\n                  \r\n                  <CardContent className=\"p-0 bg-slate-100 relative min-h-[500px]\" ref={previewContainerRef}>\r\n                    <div style={{\r\n                      transform: `scale(${previewScale})`,\r\n                      transformOrigin: 'top left',\r\n                      width: `${Math.round((1 / previewScale) * 100)}%`,\r\n                      height: 'auto',\r\n                    }}>\r\n                      <PrintSheet ref={ref} entries={list} s={s} title={title} />\r\n                    </div>\r\n                  </CardContent>\r\n                </Card>\r\n              </div>\r\n            ) : (\r\n              <div className=\"h-full flex flex-col items-center justify-center p-12 text-center space-y-6 bg-white border border-dashed border-slate-200 rounded-xl\">\r\n                <div className=\"w-16 h-16 rounded-2xl bg-slate-50 flex items-center justify-center\">\r\n                  <BookOpen className=\"h-8 w-8 text-slate-300\" />\r\n                </div>\r\n                <div className=\"space-y-2 max-w-sm\">\r\n                  <h3 className=\"text-lg font-bold text-slate-800\">BГҹв•‘В»t в”ҖГҰГҹв•‘Вәu tГҹв•‘Гӯo Worksheet</h3>\r\n                  <p className=\"text-slate-500 text-sm\">\r\n                    NhГҹв•‘ВЎp danh sв”ңГӯch chГҹв•—В» Kanji mв”ңГЎ bГҹв•‘Гӯn muГҹв•—ГҰn luyГҹв•—Г§n tГҹв•‘ВЎp vв”ңГЎo в”ңв”Ө bв”ңВ¬n trв”ңГӯi, sau в”ҖГҰв”ңв”Ӯ nhГҹв•‘Г‘n \"TГҹв•‘Гӯo\" в”ҖГҰГҹв•—Гў xem bГҹв•‘Гәn thiГҹв•‘в”җt kГҹв•‘в”җ tГҹв•‘Гӯi в”ҖГҰв”ңГіy.\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n\r\n        {/* Hidden component for canvas capture */}\r\n        {list.length === 0 && (\r\n          <div style={{ position: 'absolute', left: '-99999px', top: 0 }}>\r\n            <PrintSheet ref={ref} entries={[]} s={s} title={title} />\r\n          </div>\r\n        )}\r\n      </main>\r\n    </div>\r\n  );\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\LeaderboardPage.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\Leagues.tsx","messages":[],"suppressedMess