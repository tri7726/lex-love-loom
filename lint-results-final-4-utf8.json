ld\" />\r\n                   </div>\r\n                   Video bв”ңГЎi giГҹв•‘Гәng liв”ңВ¬n quan\r\n                </Button>\r\n              </div>\r\n\r\n              <Card className=\"bg-gradient-to-br from-indigo-500 to-indigo-700 text-white border-none shadow-indigo\">\r\n                <CardContent className=\"p-6 space-y-4\">\r\n                   <div className=\"text-indigo-200 text-xs font-bold uppercase tracking-widest\">TiГҹв•‘в”җp theo</div>\r\n                   <h3 className=\"text-xl font-bold\">Unit 2: в”ҖГүГҹв•—Гҙ vГҹв•‘ВЎt</h3>\r\n                   <p className=\"text-indigo-100 text-sm opacity-80\">HГҹв•—Г¬c cв”ңГӯch sГҹв•—ВЎ dГҹв•—Г‘ng Kore, Sore, Are vв”ңГЎ sГҹв•—Ж’ hГҹв•—В»u cв”ңГӯch.</p>\r\n                   <Button variant=\"secondary\" className=\"w-full gap-2 text-indigo-700 font-bold\">\r\n                     ChuyГҹв•—Гўn bв”ңГЎi\r\n                     <ArrowRight className=\"h-4 w-4\" />\r\n                   </Button>\r\n                </CardContent>\r\n              </Card>\r\n            </div>\r\n          </div>\r\n        </Tabs>\r\n      </main>\r\n\r\n      {/* AI Assistant */}\r\n      <UnitAIAssistant \r\n        unitId={unitId || '1'} \r\n        level={level || 'n5'} \r\n        unitTitle={contentTitle}\r\n        contextData={{ vocab: vocabData, kanji: kanjiData, grammar: grammarData }}\r\n      />\r\n    </div>\r\n  );\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\UserGuide.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\UserProfile.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\D