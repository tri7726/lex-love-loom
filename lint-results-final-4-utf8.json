 >\r\n                      <Heart \r\n                        className={`h-5 w-5 transition-colors ${\r\n                          favoriteIds.has(video.id) \r\n                            ? 'fill-red-500 text-red-500' \r\n                            : 'text-muted-foreground hover:text-red-500'\r\n                        }`} \r\n                      />\r\n                    </button>\r\n                  </div>\r\n                  <CardContent className=\"p-4\">\r\n                    <h3 className=\"font-semibold line-clamp-2\">{video.title}</h3>\r\n                    <div className=\"flex items-center justify-between mt-2\">\r\n                      <span className=\"px-2 py-0.5 rounded text-xs bg-sakura/10 text-sakura\">\r\n                        {video.jlpt_level}\r\n                      </span>\r\n                      <ChevronRight className=\"h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors\" />\r\n                    </div>\r\n                  </CardContent>\r\n                </Card>\r\n              </motion.div>\r\n            ))}\r\n          </div>\r\n        )}\r\n      </main>\r\n    </div>\r\n  );\r\n};\r\n\r\n// export default VideoLearning;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\Vocabulary.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\services\\vocabularyService.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\test\\example.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixable