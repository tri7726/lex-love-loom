tLoading(true);\r\n    \r\n    try {\r\n      const { error } = await supabase\r\n        .from('profiles')\r\n        .update({\r\n          display_name: formData.displayName,\r\n          bio: formData.bio,\r\n          jlpt_level: formData.jlptLevel,\r\n          updated_at: new Date().toISOString()\r\n        })\r\n        .eq('user_id', profile.user_id);\r\n\r\n      if (error) throw error;\r\n\r\n      toast({\r\n        title: \"Thв”ңГЎnh cв”ңв”Өng!\",\r\n        description: \"HГҹв•—Гҙ sв•һГӯ cГҹв•—Вәa bГҹв•‘Гӯn в”ҖГҰв”ңГә в”ҖГҰв•һв–‘Гҹв•—Гәc cГҹв•‘ВЎp nhГҹв•‘ВЎt.\",\r\n      });\r\n      \r\n      await refreshProfile();\r\n      navigate(`/profile/${profile.user_id}`);\r\n    } catch (error: any) {\r\n      toast({\r\n        title: \"LГҹв•—Г№i cГҹв•‘ВЎp nhГҹв•‘ВЎt\",\r\n        description: error.message,\r\n        variant: \"destructive\"\r\n      });\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background pb-20\">\r\n      <Navigation />\r\n      \r\n      <main className=\"container py-10 max-w-2xl mx-auto space-y-8\">\r\n        <Link to={profile ? `/profile/${profile.user_id}` : '/friends'}>\r\n          <Button variant=\"ghost\" className=\"gap-2 mb-4\">\r\n            <ChevronLeft className=\"h-4 w-4\" /> Quay lГҹв•‘Гӯi hГҹв•—Гҙ sв•һГӯ\r\n          </Button>\r\n        </Link>\r\n\r\n        <section className=\"space-y-6\">\r\n          <div className=\"space-y-2\">\r\n            <h1 className=\"text-4xl font-display font-bold\">ChГҹв•—Г«nh sГҹв•—ВЎa hГҹв•—Гҙ sв•һГӯ</h1>\r\n            <p className=\"text-muted-foreground\">\r\n              CГҹв•‘ВЎp nhГҹв•‘ВЎt thв”ңв”Өng tin cв”ңГӯ nhв”ңГіn в”ҖГҰГҹв•—Гў bГҹв•‘Гӯn bв”ңВҝ dГҹв•—Г  dв”ңГЎng nhГҹв•‘ВЎn diГҹв•—Г§n bГҹв•‘Гӯn.\r\n            </p>\r\n          </div>\r\n\r\n          <Card className=\"border-2 border-primary/10 shadow-soft overflow-hidden\">\r\n            <CardHeader className=\"bg-primary/5 pb-8\">\r\n              <div className=\"flex justify-center -mb-20 pt-4\">\r\n                <div className=\"relative group\">\r\n                  <div className=\"h-32 w-32 rounded-[2rem] bg-muted border-4 border-background shadow-xl flex items-center justify-center overflow-hidden\">\r\n                    <User className=\"h-16 w-16 text-muted-foreground\" />\r\n                  </div>\r\n                  <Button size=\"icon\" className=\"absolute -bottom-2 -right-2 rounded-xl shadow-lg\">\r\n                    <Camera className=\"h-4 w-4\" />\r\n                  </Button>\r\n                </div>\r\n              </div>\r\n            </CardHeader>\r\n            <CardContent className=\"pt-16 space-y-6 px-8\">\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"displayName\" className=\"text-xs font-black uppercase tracking-widest text-muted-foreground flex items-center gap-2\">\r\n                  <Type className=\"h-3 w-3\" /> Tв”ңВ¬n hiГҹв•—Гўn thГҹв•—ГҜ\r\n                </Label>\r\n                <Input \r\n                  id=\"displayName\"\r\n                  value={formData.displayName}\r\n                  onChange={(e) => setFormData({...formData, displayName: e.target.value})}\r\n                  placeholder=\"NhГҹв•‘ВЎp tв”ңВ¬n cГҹв•—Вәa bГҹв•‘Гӯn...\"\r\n                  className=\"rounded-xl border-2 h-12 focus-visible:ring-primary/20\"\r\n                />\r\n              </div>\r\n\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"jlptLevel\" className=\"text-xs font-black uppercase tracking-widest text-muted-foreground flex items-center gap-2\">\r\n                  <Book className=\"h-3 w-3\" /> Trв”ңВјnh в”ҖГҰГҹв•—Г– JLPT mГҹв•—Г‘c tiв”ңВ¬u\r\n                </Label>\r\n                <Select \r\n                  value={formData.jlptLevel} \r\n                  onValueChange={(val) => setFormData({...formData, jlptLevel: val})}\r\n                >\r\n                  <SelectTrigger className=\"rounded-xl border-2 h-12\">\r\n                    <SelectValue placeholder=\"ChГҹв•—Г¬n trв”ңВјnh в”ҖГҰГҹв•—Г–\" />\r\n                  </SelectTrigger>\r\n                  <SelectContent>\r\n                    {['N5', 'N4', 'N3', 'N2', 'N1'].map(level => (\r\n                      <SelectItem key={level} value={level}>JLPT {level}</SelectItem>\r\n                    ))}\r\n                  </SelectContent>\r\n                </Select>\r\n              </div>\r\n\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"bio\" className=\"text-xs font-black uppercase tracking-widest text-muted-foreground flex items-center gap-2\">\r\n                  LГҹв•—ВҘi giГҹв•—Вўi thiГҹв•—Г§u (Bio)\r\n                </Label>\r\n                <Textarea \r\n                  id=\"bio\"\r\n                  value={formData.bio}\r\n                  onChange={(e) => setFormData({...formData, bio: e.target.value})}\r\n                  placeholder=\"Chia sГҹв•‘в•— mГҹв•—Г–t chв”ңв•‘t vГҹв•—Гј mГҹв•—Г‘c tiв”ңВ¬u hГҹв•—Г¬c tГҹв•‘ВЎp cГҹв•—Вәa bГҹв•‘Гӯn...\"\r\n                  className=\"rounded-xl border-2 min-h-[120px] focus-visible:ring-primary/20\"\r\n                />\r\n              </div>\r\n\r\n              <div className=\"p-4 rounded-xl bg-secondary/10 border border-secondary/20 flex gap-3 text-sm text-secondary-foreground\">\r\n                <AlertCircle className=\"h-5 w-5 flex-shrink-0\" />\r\n                <p>Thв”ңв”Өng tin nв”ңГЎy sГҹв•‘в•ң в”ҖГҰв•һв–‘Гҹв•—Гәc hiГҹв•—Гўn thГҹв•—ГҜ cв”ңв”Өng khai cho tГҹв•‘Г‘t cГҹв•‘Гә ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng trong cГҹв•—Г–ng в”ҖГҰГҹв•—Гҙng.</p>\r\n              </div>\r\n            </CardContent>\r\n            <CardFooter className=\"px-8 pb-8 flex gap-3\">\r\n              <Button \r\n                onClick={handleSave} \r\n                disabled={loading}\r\n                className=\"flex-1 rounded-xl h-12 shadow-sakura font-bold gap-2\"\r\n              >\r\n                {loading ? <Loader2 className=\"h-4 w-4 animate-spin\" /> : <Save className=\"h-4 w-4\" />}\r\n                Lв•һв–‘u thay в”ҖГҰГҹв•—ГІi\r\n              </Button>\r\n            </CardFooter>\r\n          </Card>\r\n        </section>\r\n      </main>\r\n    </div>\r\n  );\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\FlashcardGames.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchVocabulary'. Either include it or remove the dependency array.","line":107,"column":6,"nodeType":"ArrayExpression","endLine":107,"endColumn":12,"suggestions":[{"desc":"Update the dependencies array to be: [fetchVocabulary, user]","fix":{"range":[3112,3118],"text":"[fetchVocabulary, user]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\r\nimport { motion } from 'framer-motion';\r\nimport { \r\n  Gamepad2, \r\n  Shuffle, \r\n  CheckCircle2, \r\n  Keyboard, \r\n  Headphones, \r\n  Zap,\r\n  ArrowLeft,\r\n  Trophy,\r\n  Star\r\n} from 'lucide-react';\r\nimport { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Badge } from '@/components/ui/badge';\r\nimport { Navigation } from '@/components/Navigation';\r\nimport { useAuth } from '@/hooks/useAuth';\r\nimport { supabase } from '@/integrations/supabase/client';\r\nimport { MatchGame } from '@/components/games/MatchGame';\r\nimport { MultipleChoiceGame } from '@/components/games/MultipleChoiceGame';\r\nimport { WriteGame } from '@/components/games/WriteGame';\r\nimport { ListeningGame } from '@/components/games/ListeningGame';\r\nimport { TypingGame } from '@/components/games/TypingGame';\r\nimport { SpeedGame } from '@/components/games/SpeedGame';\r\nimport { useToast } from '@/hooks/use-toast';\r\nimport { VocabularyItem } from '@/types/vocabulary';\r\n\r\n\r\ntype GameMode = 'hub' | 'match' | 'quiz' | 'write' | 'listening' | 'speed' | 'typing';\r\n\r\nconst gameModes = [\r\n  {\r\n    id: 'match' as GameMode,\r\n    title: 'Match Game',\r\n    titleVi: 'Ghв”ңвҢҗp CГҹв•‘в•–p',\r\n    description: 'Ghв”ңвҢҗp tГҹв•—ВҪ tiГҹв•‘в”җng NhГҹв•‘ВЎt vГҹв•—Вўi nghв”ҖвҢҗa tiГҹв•‘в”җng ViГҹв•—Г§t',\r\n    icon: Shuffle,\r\n    color: 'bg-blue-500',\r\n    difficulty: 'DГҹв•—Г ',\r\n  },\r\n  {\r\n    id: 'quiz' as GameMode,\r\n    title: 'Multiple Choice',\r\n    titleVi: 'TrГҹв•‘В»c NghiГҹв•—Г§m',\r\n    description: 'ChГҹв•—Г¬n в”ҖГҰв”ңГӯp в”ңГӯn в”ҖГҰв”ңв•‘ng tГҹв•—ВҪ 4 lГҹв•—в–’a chГҹв•—Г¬n',\r\n    icon: CheckCircle2,\r\n    color: 'bg-green-500',\r\n    difficulty: 'Trung bв”ңВјnh',\r\n  },\r\n  {\r\n    id: 'typing' as GameMode,\r\n    title: 'Typing Practice',\r\n    titleVi: 'LuyГҹв•—Г§n Gв”ңв•Ў TГҹв•—ВҪ',\r\n    description: 'LuyГҹв•—Г§n gв”ңв•Ў tГҹв•—ВҪ tiГҹв•‘в”җng NhГҹв•‘ВЎt theo nghв”ҖвҢҗa',\r\n    icon: Keyboard,\r\n    color: 'bg-indigo-500',\r\n    difficulty: 'Trung bв”ңВјnh',\r\n  },\r\n  {\r\n    id: 'write' as GameMode,\r\n    title: 'Write Answer',\r\n    titleVi: 'Gв”ңв•Ў в”ҖГүв”ңГӯp в”ңГјn',\r\n    description: 'Gв”ңв•Ў cв”ңГіu trГҹв•‘Гә lГҹв•—ВҘi bГҹв•‘в–’ng Hiragana hoГҹв•‘в•–c Kanji',\r\n    icon: Keyboard,\r\n    color: 'bg-purple-500',\r\n    difficulty: 'Khв”ңв”Ӯ',\r\n  },\r\n  {\r\n    id: 'listening' as GameMode,\r\n    title: 'Listening Challenge',\r\n    titleVi: 'Nghe HiГҹв•—Гўu',\r\n    description: 'Nghe vв”ңГЎ chГҹв•—Г¬n в”ҖГҰв”ңГӯp в”ңГӯn в”ҖГҰв”ңв•‘ng',\r\n    icon: Headphones,\r\n    color: 'bg-orange-500',\r\n    difficulty: 'Trung bв”ңВјnh',\r\n  },\r\n  {\r\n    id: 'speed' as GameMode,\r\n    title: 'Speed Mode',\r\n    titleVi: 'TГҹв•—ГҰc в”ҖГүГҹв•—Г–',\r\n    description: 'TrГҹв•‘Гә lГҹв•—ВҘi nhanh в”ҖГҰГҹв•—Гў tв”ҖГўng combo в”ҖГҰiГҹв•—Гўm',\r\n    icon: Zap,\r\n    color: 'bg-red-500',\r\n    difficulty: 'ThГҹв•—ВЎ thв”ңГӯch',\r\n  },\r\n];\r\n\r\nexport const FlashcardGames = () => {\r\n  const { user } = useAuth();\r\n  const { toast } = useToast();\r\n  const [vocabulary, setVocabulary] = useState<VocabularyItem[]>([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [currentGame, setCurrentGame] = useState<GameMode>('hub');\r\n  const [gameStats, setGameStats] = useState({\r\n    totalPlayed: 0,\r\n    correctAnswers: 0,\r\n    streak: 0,\r\n  });\r\n\r\n  useEffect(() => {\r\n    if (user) {\r\n      fetchVocabulary();\r\n    } else {\r\n      setLoading(false);\r\n    }\r\n  }, [user]);\r\n\r\n  const fetchVocabulary = async () => {\r\n    try {\r\n      const { data, error } = await supabase\r\n        .from('saved_vocabulary')\r\n        .select('id, word, reading, meaning, mastery_level')\r\n        .eq('user_id', user!.id)\r\n        .order('created_at', { ascending: false });\r\n\r\n      if (error) throw error;\r\n      setVocabulary(data || []);\r\n    } catch (error) {\r\n      console.error('Error fetching vocabulary:', error);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const updateMasteryLevel = async (wordId: string, correct: boolean) => {\r\n    const word = vocabulary.find(v => v.id === wordId);\r\n    if (!word) return;\r\n\r\n    const currentLevel = word.mastery_level || 0;\r\n    const newLevel = correct \r\n      ? Math.min(currentLevel + 1, 5) \r\n      : Math.max(currentLevel - 1, 0);\r\n\r\n    try {\r\n      await supabase\r\n        .from('saved_vocabulary')\r\n        .update({ mastery_level: newLevel })\r\n        .eq('id', wordId);\r\n\r\n      setVocabulary(prev => \r\n        prev.map(v => v.id === wordId ? { ...v, mastery_level: newLevel } : v)\r\n      );\r\n    } catch (error) {\r\n      console.error('Error updating mastery level:', error);\r\n    }\r\n  };\r\n\r\n  const handleGameComplete = (results: { correct: number; total: number }) => {\r\n    setGameStats(prev => ({\r\n      totalPlayed: prev.totalPlayed + results.total,\r\n      correctAnswers: prev.correctAnswers + results.correct,\r\n      streak: results.correct === results.total ? prev.streak + 1 : 0,\r\n    }));\r\n\r\n    toast({\r\n      title: 'вүЎЖ’Г„Г« Hoв”ңГЎn thв”ңГЎnh!',\r\n      description: `BГҹв•‘Гӯn в”ҖГҰв”ңГә trГҹв•‘Гә lГҹв•—ВҘi в”ҖГҰв”ңв•‘ng ${results.correct}/${results.total} cв”ңГіu!`,\r\n    });\r\n  };\r\n\r\n  const renderGameHub = () => (\r\n    <div className=\"space-y-6\">\r\n      {/* Header */}\r\n      <div className=\"text-center space-y-2\">\r\n        <h1 className=\"text-3xl font-display font-bold flex items-center justify-center gap-2\">\r\n          <Gamepad2 className=\"h-8 w-8 text-primary\" />\r\n          Flashcard Games\r\n        </h1>\r\n        <p className=\"text-muted-foreground\">\r\n          HГҹв•—Г¬c tГҹв•—ВҪ vГҹв•—в–’ng qua cв”ңГӯc trв”ңв–“ chв•һГӯi thв”ңв•‘ vГҹв•—ГҜ\r\n        </p>\r\n      </div>\r\n\r\n      {/* Stats */}\r\n      <div className=\"grid grid-cols-3 gap-4\">\r\n        <Card className=\"text-center\">\r\n          <CardContent className=\"pt-4\">\r\n            <Trophy className=\"h-6 w-6 mx-auto text-yellow-500 mb-2\" />\r\n            <p className=\"text-2xl font-bold\">{vocabulary.length}</p>\r\n            <p className=\"text-xs text-muted-foreground\">TГҹв•—ВҪ vГҹв•—в–’ng</p>\r\n          </CardContent>\r\n        </Card>\r\n        <Card className=\"text-center\">\r\n          <CardContent className=\"pt-4\">\r\n            <Star className=\"h-6 w-6 mx-auto text-orange-500 mb-2\" />\r\n            <p className=\"text-2xl font-bold\">{gameStats.correctAnswers}</p>\r\n            <p className=\"text-xs text-muted-foreground\">в”ҖГүв”ңв•‘ng</p>\r\n          </CardContent>\r\n        </Card>\r\n        <Card className=\"text-center\">\r\n          <CardContent className=\"pt-4\">\r\n            <Zap className=\"h-6 w-6 mx-auto text-red-500 mb-2\" />\r\n            <p className=\"text-2xl font-bold\">{gameStats.streak}</p>\r\n            <p className=\"text-xs text-muted-foreground\">Streak</p>\r\n          </CardContent>\r\n        </Card>\r\n      </div>\r\n\r\n      {/* Check if user has vocabulary */}\r\n      {!user ? (\r\n        <Card className=\"bg-muted/50\">\r\n          <CardContent className=\"py-8 text-center\">\r\n            <p className=\"text-muted-foreground\">\r\n              Vui lв”ңв–“ng в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp в”ҖГҰГҹв•—Гў chв•һГӯi game hГҹв•—Г¬c tГҹв•—ВҪ vГҹв•—в–’ng\r\n            </p>\r\n            <Button className=\"mt-4\" onClick={() => window.location.href = '/auth'}>\r\n              в”ҖГүв”ҖГўng nhГҹв•‘ВЎp\r\n            </Button>\r\n          </CardContent>\r\n        </Card>\r\n      ) : vocabulary.length < 4 ? (\r\n        <Card className=\"bg-muted/50\">\r\n          <CardContent className=\"py-8 text-center\">\r\n            <p className=\"text-muted-foreground\">\r\n              BГҹв•‘Гӯn cГҹв•‘Вәn в”ңВЎt nhГҹв•‘Г‘t 4 tГҹв•—ВҪ vГҹв•—в–’ng в”ҖГҰГҹв•—Гў chв•һГӯi game.\r\n              <br />\r\n              HiГҹв•—Г§n cв”ңв”Ӯ: {vocabulary.length} tГҹв•—ВҪ\r\n            </p>\r\n            <Button className=\"mt-4\" onClick={() => window.location.href = '/video-learning'}>\r\n              HГҹв•—Г¬c tГҹв•—ВҪ mГҹв•—Вўi\r\n            </Button>\r\n          </CardContent>\r\n        </Card>\r\n      ) : (\r\n        /* Game Modes */\r\n        <div className=\"grid gap-4 md:grid-cols-2\">\r\n          {gameModes.map((mode) => {\r\n            const Icon = mode.icon;\r\n            return (\r\n              <motion.div\r\n                key={mode.id}\r\n                whileHover={{ scale: 1.02 }}\r\n                whileTap={{ scale: 0.98 }}\r\n              >\r\n                <Card \r\n                  className=\"cursor-pointer hover:shadow-lg transition-all border-2 hover:border-primary/30\"\r\n                  onClick={() => setCurrentGame(mode.id)}\r\n                >\r\n                  <CardHeader className=\"pb-3\">\r\n                    <div className=\"flex items-center gap-3\">\r\n                      <div className={`p-3 rounded-lg ${mode.color} text-white`}>\r\n                        <Icon className=\"h-6 w-6\" />\r\n                      </div>\r\n                      <div className=\"flex-1\">\r\n                        <CardTitle className=\"text-lg\">{mode.titleVi}</CardTitle>\r\n                        <CardDescription className=\"text-xs\">{mode.title}</CardDescription>\r\n                      </div>\r\n                      <Badge variant=\"outline\">{mode.difficulty}</Badge>\r\n                    </div>\r\n                  </CardHeader>\r\n                  <CardContent className=\"pt-0\">\r\n                    <p className=\"text-sm text-muted-foreground\">{mode.description}</p>\r\n                  </CardContent>\r\n                </Card>\r\n              </motion.div>\r\n            );\r\n          })}\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n\r\n  const renderGame = () => {\r\n    const gameProps = {\r\n      vocabulary,\r\n      onComplete: handleGameComplete,\r\n      onUpdateMastery: updateMasteryLevel,\r\n      onBack: () => setCurrentGame('hub'),\r\n    };\r\n\r\n    switch (currentGame) {\r\n      case 'match':\r\n        return <MatchGame {...gameProps} />;\r\n      case 'quiz':\r\n        return <MultipleChoiceGame {...gameProps} />;\r\n      case 'typing':\r\n        return <TypingGame {...gameProps} />;\r\n      case 'write':\r\n        return <WriteGame {...gameProps} />;\r\n      case 'listening':\r\n        return <ListeningGame {...gameProps} />;\r\n      case 'speed':\r\n        return <SpeedGame {...gameProps} />;\r\n      default:\r\n        return renderGameHub();\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background pb-20 md:pb-0\">\r\n        <Navigation />\r\n        <main className=\"container py-6\">\r\n          <div className=\"flex justify-center items-center min-h-[400px]\">\r\n            <div className=\"animate-spin rounded-full h-8 w-8 border-b-2 border-primary\"></div>\r\n          </div>\r\n        </main>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background pb-20 md:pb-0\">\r\n      <Navigation />\r\n      <main className=\"container py-6\">\r\n        <div className=\"max-w-3xl mx-auto\">\r\n          {currentGame !== 'hub' && (\r\n            <Button \r\n              variant=\"ghost\" \r\n              onClick={() => setCurrentGame('hub')}\r\n              className=\"mb-4 gap-2\"\r\n            >\r\n              <ArrowLeft className=\"h-4 w-4\" />\r\n              Quay lГҹв•‘Гӯi\r\n            </Button>\r\n          )}\r\n          {renderGame()}\r\n        </div>\r\n      </main>\r\n    </div>\r\n  );\r\n};\r\n\r\n// export default FlashcardGames;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\FlashcardReview.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchFolders'. Either include it or remove the dependency array.","line":53,"column":6,"nodeType":"ArrayExpression","endLine":53,"endColumn":12,"suggestions":[{"desc":"Update the dependencies array to be: [fetchFolders, user]","fix":{"range":[1758,1764],"text":"[fetchFolders, user]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchFlashcards'. Either include it or remove the dependency array.","line":59,"column":6,"nodeType":"ArrayExpression","endLine":59,"endColumn":28,"suggestions":[{"desc":"Update the dependencies array to be: [user, selectedFolder, fetchFlashcards]","fix":{"range":[1878,1900],"text":"[user, selectedFolder, fetchFlashcards]"}}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify 