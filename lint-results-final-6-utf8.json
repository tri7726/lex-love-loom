tate('');\r\n  const navigate = useNavigate();\r\n\r\n  useEffect(() => {\r\n    const { data: { subscription } } = supabase.auth.onAuthStateChange((event, session) => {\r\n      if (session?.user) {\r\n        navigate('/');\r\n      }\r\n    });\r\n\r\n    supabase.auth.getSession().then(({ data: { session } }) => {\r\n      if (session?.user) {\r\n        navigate('/');\r\n      }\r\n    });\r\n\r\n    return () => subscription.unsubscribe();\r\n  }, [navigate]);\r\n\r\n  const validateInputs = () => {\r\n    try {\r\n      emailSchema.parse(email);\r\n      passwordSchema.parse(password);\r\n      return true;\r\n    } catch (error) {\r\n      if (error instanceof z.ZodError) {\r\n        toast.error('Lß╗ùi x├íc thß╗▒c', {\r\n          description: error.errors[0].message,\r\n        });\r\n      }\r\n      return false;\r\n    }\r\n  };\r\n\r\n  const handleLogin = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    if (!validateInputs()) return;\r\n\r\n    setIsLoading(true);\r\n    try {\r\n      const { error } = await supabase.auth.signInWithPassword({\r\n        email,\r\n        password,\r\n      });\r\n\r\n      if (error) {\r\n        let message = error.message;\r\n        if (error.message.includes('Invalid login credentials')) {\r\n          message = 'Email hoß║╖c mß║¡t khß║⌐u kh├┤ng ─æ├║ng';\r\n        } else if (error.message.includes('Email not confirmed')) {\r\n          message = 'Vui l├▓ng x├íc nhß║¡n email tr╞░ß╗¢c khi ─æ─âng nhß║¡p';\r\n        }\r\n        throw new Error(message);\r\n      }\r\n\r\n      toast.success('─É─âng nhß║¡p th├ánh c├┤ng!', {\r\n        description: 'Ch├áo mß╗½ng bß║ín quay trß╗ƒ lß║íi!',\r\n      });\r\n    } catch (error: any) {\r\n      toast.error('Lß╗ùi ─æ─âng nhß║¡p', {\r\n        description: error.message,\r\n      });\r\n    } finally {\r\n      setIsLoading(false);\r\n    }\r\n  };\r\n\r\n  const handleSignup = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    if (!validateInputs()) return;\r\n\r\n    setIsLoading(true);\r\n    try {\r\n      const redirectUrl = `${window.location.origin}/`;\r\n      \r\n      const { error } = await supabase.auth.signUp({\r\n        email,\r\n        password,\r\n        options: {\r\n          emailRedirectTo: redirectUrl,\r\n          data: {\r\n            display_name: displayName || email.split('@')[0],\r\n          },\r\n        },\r\n      });\r\n\r\n      if (error) {\r\n        let message = error.message;\r\n        if (error.message.includes('User already registered')) {\r\n          message = 'Email n├áy ─æ├ú ─æ╞░ß╗úc ─æ─âng k├╜. Vui l├▓ng ─æ─âng nhß║¡p.';\r\n        }\r\n        throw new Error(message);\r\n      }\r\n\r\n      toast.success('─É─âng k├╜ th├ánh c├┤ng!', {\r\n        description: 'Vui l├▓ng kiß╗âm tra email ─æß╗â x├íc nhß║¡n t├ái khoß║ún.',\r\n      });\r\n    } catch (error: any) {\r\n      toast.error('Lß╗ùi ─æ─âng k├╜', {\r\n        description: error.message,\r\n      });\r\n    } finally {\r\n      setIsLoading(false);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-gradient-to-b from-background to-sakura/10 flex items-center justify-center p-4\">\r\n      <motion.div\r\n        initial={{ opacity: 0, y: 20 }}\r\n        animate={{ opacity: 1, y: 0 }}\r\n        transition={{ duration: 0.5 }}\r\n        className=\"w-full max-w-md\"\r\n      >\r\n        <div className=\"text-center mb-8\">\r\n          <h1 className=\"text-4xl font-display font-bold text-primary mb-2\">µùÑµ£¼Φ¬₧πâ₧πé╣πé┐πâ╝</h1>\r\n          <p className=\"text-muted-foreground\">Hß╗ìc tiß║┐ng Nhß║¡t th├┤ng minh vß╗¢i AI</p>\r\n        </div>\r\n\r\n        <Card className=\"shadow-card border-sakura/20\">\r\n          <CardHeader className=\"text-center\">\r\n            <CardTitle className=\"text-2xl\">Ch├áo mß╗½ng!</CardTitle>\r\n            <CardDescription>─É─âng nhß║¡p hoß║╖c tß║ío t├ái khoß║ún mß╗¢i</CardDescription>\r\n          </CardHeader>\r\n          <CardContent>\r\n            <Tabs defaultValue=\"login\" className=\"w-full\">\r\n              <TabsList className=\"grid w-full grid-cols-2 mb-6\">\r\n                <TabsTrigger value=\"login\">─É─âng nhß║¡p</TabsTrigger>\r\n                <TabsTrigger value=\"signup\">─É─âng k├╜</TabsTrigger>\r\n              </TabsList>\r\n\r\n              <TabsContent value=\"login\">\r\n                <form onSubmit={handleLogin} className=\"space-y-4\">\r\n                  <div className=\"space-y-2\">\r\n                    <Label htmlFor=\"login-email\">Email</Label>\r\n                    <div className=\"relative\">\r\n                      <Mail className=\"absolute left-3 top-3 h-4 w-4 text-muted-foreground\" />\r\n                      <Input\r\n                        id=\"login-email\"\r\n                        type=\"email\"\r\n                        placeholder=\"email@example.com\"\r\n                        value={email}\r\n                        onChange={(e) => setEmail(e.target.value)}\r\n                        className=\"pl-10\"\r\n                        required\r\n                      />\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"space-y-2\">\r\n                    <Label htmlFor=\"login-password\">Mß║¡t khß║⌐u</Label>\r\n                    <div className=\"relative\">\r\n                      <Lock className=\"absolute left-3 top-3 h-4 w-4 text-muted-foreground\" />\r\n                      <Input\r\n                        id=\"login-password\"\r\n                        type={showPassword ? 'text' : 'password'}\r\n                        placeholder=\"ΓÇóΓÇóΓÇóΓÇóΓÇóΓÇóΓÇóΓÇó\"\r\n                        value={password}\r\n                        onChange={(e) => setPassword(e.target.value)}\r\n                        className=\"pl-10 pr-10\"\r\n                        required\r\n                      />\r\n                      <button\r\n                        type=\"button\"\r\n                        onClick={() => setShowPassword(!showPassword)}\r\n                        className=\"absolute right-3 top-3 text-muted-foreground hover:text-foreground\"\r\n                      >\r\n                        {showPassword ? <EyeOff className=\"h-4 w-4\" /> : <Eye className=\"h-4 w-4\" />}\r\n                      </button>\r\n                    </div>\r\n                  </div>\r\n\r\n                  <Button type=\"submit\" className=\"w-full\" disabled={isLoading}>\r\n                    {isLoading ? (\r\n                      <>\r\n                        <Loader2 className=\"mr-2 h-4 w-4 animate-spin\" />\r\n                        ─Éang ─æ─âng nhß║¡p...\r\n                      </>\r\n                    ) : (\r\n                      '─É─âng nhß║¡p'\r\n                    )}\r\n                  </Button>\r\n                </form>\r\n              </TabsContent>\r\n\r\n              <TabsContent value=\"signup\">\r\n                <form onSubmit={handleSignup} className=\"space-y-4\">\r\n                  <div className=\"space-y-2\">\r\n                    <Label htmlFor=\"signup-name\">T├¬n hiß╗ân thß╗ï</Label>\r\n                    <div className=\"relative\">\r\n                      <User className=\"absolute left-3 top-3 h-4 w-4 text-muted-foreground\" />\r\n                      <Input\r\n                        id=\"signup-name\"\r\n                        type=\"text\"\r\n                        placeholder=\"T├¬n cß╗ºa bß║ín\"\r\n                        value={displayName}\r\n                        onChange={(e) => setDisplayName(e.target.value)}\r\n                        className=\"pl-10\"\r\n                      />\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"space-y-2\">\r\n                    <Label htmlFor=\"signup-email\">Email</Label>\r\n                    <div className=\"relative\">\r\n                      <Mail className=\"absolute left-3 top-3 h-4 w-4 text-muted-foreground\" />\r\n                      <Input\r\n                        id=\"signup-email\"\r\n                        type=\"email\"\r\n                        placeholder=\"email@example.com\"\r\n                        value={email}\r\n                        onChange={(e) => setEmail(e.target.value)}\r\n                        className=\"pl-10\"\r\n                        required\r\n                      />\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"space-y-2\">\r\n                    <Label htmlFor=\"signup-password\">Mß║¡t khß║⌐u</Label>\r\n                    <div className=\"relative\">\r\n                      <Lock className=\"absolute left-3 top-3 h-4 w-4 text-muted-foreground\" />\r\n                      <Input\r\n                        id=\"signup-password\"\r\n                        type={showPassword ? 'text' : 'password'}\r\n                        placeholder=\"Tß╗æi thiß╗âu 6 k├╜ tß╗▒\"\r\n                        value={password}\r\n                        onChange={(e) => setPassword(e.target.value)}\r\n                        className=\"pl-10 pr-10\"\r\n                        required\r\n                      />\r\n                      <button\r\n                        type=\"button\"\r\n                        onClick={() => setShowPassword(!showPassword)}\r\n                        className=\"absolute right-3 top-3 text-muted-foreground hover:text-foreground\"\r\n                      >\r\n                        {showPassword ? <EyeOff className=\"h-4 w-4\" /> : <Eye className=\"h-4 w-4\" />}\r\n                      </button>\r\n                    </div>\r\n                  </div>\r\n\r\n                  <Button type=\"submit\" className=\"w-full\" disabled={isLoading}>\r\n                    {isLoading ? (\r\n                      <>\r\n                        <Loader2 className=\"mr-2 h-4 w-4 animate-spin\" />\r\n                        ─Éang ─æ─âng k├╜...\r\n                      </>\r\n                    ) : (\r\n                      '─É─âng k├╜'\r\n                    )}\r\n                  </Button>\r\n                </form>\r\n              </TabsContent>\r\n            </Tabs>\r\n          </CardContent>\r\n        </Card>\r\n\r\n        <p className=\"text-center text-sm text-muted-foreground mt-4\">\r\n          Bß║▒ng viß╗çc ─æ─âng k├╜, bß║ín ─æß╗ông ├╜ vß╗¢i ─æiß╗üu khoß║ún sß╗¡ dß╗Ñng cß╗ºa ch├║ng t├┤i.\r\n        </p>\r\n      </motion.div>\r\n    </div>\r\n  );\r\n};\r\n\r\n// export default Auth;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\Challenges.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Pheo\\OneDrive\\Documents\\GitHub\\lex-love-loom\\src\\pages\\EditProfile.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":48,"column":26,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":48,"endColumn":29,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1395,1398],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1395,1398],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":78,"column":21,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":78,"endColumn":24,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2164,2167],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is corre